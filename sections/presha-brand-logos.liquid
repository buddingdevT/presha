{%- comment -%}
  ============================================================================
  PRESHA BRAND LOGOS — Shop By Brand
  ============================================================================

  PURPOSE:
  Displays partner brand logos in a horizontally scrollable row of cards.
  Each card links to the brand's collection page.

  LAYOUT:
  - "AUTHENTICATED PARTNERSHIPS" eyebrow above heading
  - Left-aligned heading "SHOP BY BRAND"
  - Horizontal row of uniform white cards with subtle border
  - Each card contains either a logo SVG/image OR text fallback
  - Row scrolls horizontally on all viewports (hidden scrollbar, touch-friendly)
  - Cards snap to center on scroll

  INTERACTIONS:
  - Hover: card lifts slightly + drop shadow appears
  - GSAP ScrollTrigger: heading fades in, cards stagger up on scroll

  CUSTOMISATION (Theme Editor):
  - section.settings.eyebrow  → small text above heading (leave blank to hide)
  - section.settings.heading  → main heading text
  - Each block has: brand_name, logo_asset (filename), logo (image_picker), collection_url

  LOGO PRIORITY (per card):
  1. logo_asset → SVG file in assets/ folder (e.g. "brand-nike.svg")
  2. logo       → image_picker upload via Theme Editor
  3. brand_name → bold text fallback

  TO ADD BRAND LOGOS:
  1. Place the SVG file in the assets/ folder with "brand-" prefix
  2. In Theme Editor → this section → click a Brand block
  3. Enter the filename in "Logo Asset Filename" (e.g. "brand-nike.svg")
  4. OR upload an image to the "Brand Logo" image picker field

  FILES RELATED:
  - templates/index.json  → block data (brand names, URLs, block order)
  - assets/brand-*.svg    → brand logo SVG files
  - This file only        → all HTML, CSS, JS are self-contained
  ============================================================================
{%- endcomment -%}

<section
  id="presha-brand-logos-{{ section.id }}"
  class="presha-brand-logos"
  aria-label="Shop by Brand"
>

  {%- comment -%} ── Heading block ── {%- endcomment -%}
  <div class="presha-brand-logos__heading-wrap">

    {%- comment -%} Eyebrow — only renders if text is provided in Theme Editor {%- endcomment -%}
    {%- if section.settings.eyebrow != blank -%}
      <p class="presha-brand-logos__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    <h2 class="presha-brand-logos__title">{{ section.settings.heading }}</h2>
  </div>

  {%- comment -%} ── Scrollable brand card row ── {%- endcomment -%}
  <div class="presha-brand-logos__inner">
    <div class="presha-brand-logos__track" role="list">

      {%- for block in section.blocks -%}
        {%- if block.type == 'brand' -%}
          <a
            class="presha-brand-logos__card"
            href="{{ block.settings.collection_url | default: '#' }}"
            aria-label="Shop {{ block.settings.brand_name }}"
            role="listitem"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.logo_asset != blank -%}
              {%- comment -%} SVG logo from assets/ folder — highest priority {%- endcomment -%}
              <img
                class="presha-brand-logos__img"
                src="{{ block.settings.logo_asset | asset_url }}"
                alt="{{ block.settings.brand_name }}"
                loading="lazy"
                width="130"
                height="50"
              >
            {%- elsif block.settings.logo != blank -%}
              {%- comment -%} Logo image — uploaded via Theme Editor {%- endcomment -%}
              {{
                block.settings.logo
                | image_url: width: 400
                | image_tag:
                  loading: 'lazy',
                  class: 'presha-brand-logos__img',
                  alt: block.settings.brand_name,
                  width: block.settings.logo.width,
                  height: block.settings.logo.height
              }}
            {%- else -%}
              {%- comment -%} Text fallback — shown until a logo is uploaded {%- endcomment -%}
              <span class="presha-brand-logos__brand-name">{{ block.settings.brand_name }}</span>
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</section>

{% stylesheet %}

  /* ============================================================================
     SHOP BY BRAND — Styles
     ============================================================================
     STRUCTURE:
     .presha-brand-logos              → section wrapper (white bg, reduced padding)
       __heading-wrap                 → heading container (left-aligned)
         __eyebrow                    → small burgundy label above heading
         __title                      → "SHOP BY BRAND" heading
       __inner                        → scroll container (hides overflow chrome)
         __track                      → flex row, overflow-x scroll, hidden scrollbar
           __card                     → individual brand card (white, border, rounded)
             __img                    → logo image (SVG or uploaded)
             __brand-name             → text fallback (when no logo)

     SPACING:
     - Section padding: 40px top, 48px bottom (desktop)
     - Heading margin-bottom: 28px
     - Card gap: 18px
     - Card internal padding: 32px (centers the logo/text)

     HOVER:
     - Card lifts 3px + drop shadow appears
     - Text turns burgundy / logo darkens

     To change card size → edit width/height on .__card
     To change gap       → edit gap on .__track
     To change shadow    → edit box-shadow on .__card:hover
     ============================================================================ */

  /* ── Section wrapper ─────────────────────────────────────────────────────── */
  /* White background, tight vertical padding to reduce section height         */
  .presha-brand-logos {
    width: 100%;
    background-color: #ffffff;
    padding: 40px 0 48px;        /* CHANGE: reduce top/bottom padding here    */
    box-sizing: border-box;
    overflow: hidden;
  }

  /* ── Heading block — left-aligned ────────────────────────────────────────── */
  /* Matches design ref: heading sits left within the content area             */
  .presha-brand-logos__heading-wrap {
    text-align: center;
    margin-bottom: 28px;         /* CHANGE: space between heading and cards   */
    padding: 0 40px;
    max-width: 1380px;
    margin-left: auto;
    margin-right: auto;
    opacity: 0;                  /* GSAP animates this to 1 on scroll         */
    will-change: opacity, transform;
  }

  /* Eyebrow — small burgundy label (optional, hidden if blank in Liquid)     */
  .presha-brand-logos__eyebrow {
    font-family: var(--font-body-family, 'Jost', system-ui, sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #6B1A2A;              /* Presha burgundy                           */
    margin: 0 0 8px;
    line-height: 1;
  }

  /* Main heading — editorial Cormorant Garamond italic                        */
  .presha-brand-logos__title {
    font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 600;
    font-style: italic;
    letter-spacing: -0.01em;
    color: #0A0A0A;
    margin: 0;
    line-height: 1.1;
  }

  /* ── Scroll container ────────────────────────────────────────────────────── */
  /* Constrains the track width and hides any overflow chrome                  */
  .presha-brand-logos__inner {
    max-width: 1380px;
    margin: 0 auto;
    padding: 0;
    overflow: hidden;
  }

  /* ── Card track — horizontal scroll on ALL viewports ─────────────────────── */
  /* Flex row, no wrap, scrolls horizontally, scrollbar hidden                  */
  /* CHANGE: adjust gap to change space between cards                           */
  /* CHANGE: adjust padding to change edge insets                               */
  .presha-brand-logos__track {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 18px;                   /* CHANGE: gap between cards                  */
    flex-wrap: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 8px 40px 16px;      /* top/sides/bottom — extra bottom for shadow */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .presha-brand-logos__track::-webkit-scrollbar {
    display: none;
  }

  /* ── Brand card ──────────────────────────────────────────────────────────── */
  /* White card with subtle gray border, rounded corners                       */
  /* Sized wider to match design ref — generous padding around logos            */
  /* CHANGE: width/height to resize cards                                      */
  /* CHANGE: border-radius for corner roundness                                */
  /* CHANGE: border color for card outline                                     */
  .presha-brand-logos__card {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    scroll-snap-align: center;
    text-decoration: none;
    width: 200px;                /* CHANGE: card width                         */
    height: 130px;               /* CHANGE: card height                        */
    padding: 20px;               /* CHANGE: internal padding around logo       */
    background: #ffffff;
    border: 1px solid #e5e5e8;   /* subtle light gray border                   */
    border-radius: 12px;         /* CHANGE: card corner radius                 */
    opacity: 0;                  /* GSAP animates to 1                         */
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    will-change: opacity, transform, box-shadow;
    transition:
      transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      box-shadow 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      opacity 0.3s ease;
  }

  /* ── Card hover — lift + drop shadow ─────────────────────────────────────── */
  /* CHANGE: box-shadow values to adjust shadow intensity/spread                */
  /* CHANGE: translateY to adjust lift distance                                 */
  .presha-brand-logos__card:hover,
  .presha-brand-logos__card:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.10), 0 2px 8px rgba(0, 0, 0, 0.06);
    outline: none;
  }

  /* ── Brand name text (fallback until logo is uploaded) ───────────────────── */
  /* Bold uppercase text centered inside the card                               */
  /* CHANGE: font-size for text size, color for text color                      */
  .presha-brand-logos__brand-name {
    font-family: var(--font-body-family, 'Jost', system-ui, sans-serif);
    font-size: 14px;             /* CHANGE: fallback text size                 */
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #1e2235;              /* dark navy                                  */
    line-height: 1.25;
    text-align: center;
    display: block;
    white-space: nowrap;
    padding: 0 12px;
    transition: color 0.3s ease;
  }

  /* Text turns burgundy on hover                                               */
  .presha-brand-logos__card:hover .presha-brand-logos__brand-name,
  .presha-brand-logos__card:focus-visible .presha-brand-logos__brand-name {
    color: #6B1A2A;
  }

  /* ── Logo images (SVG from assets/ or uploaded via Theme Editor) ────────── */
  /* Black logos displayed at a max size to fit uniformly inside cards           */
  /* CHANGE: max-height to resize logos, max-width to constrain width           */
  .presha-brand-logos__img {
    display: block;
    max-height: 55px;            /* CHANGE: logo max height inside card        */
    max-width: 140px;            /* CHANGE: logo max width inside card         */
    width: auto;
    height: auto;
    object-fit: contain;
    transition: opacity 0.3s ease;
  }

  /* ── Tablet (750px–1079px) ───────────────────────────────────────────────── */
  @media screen and (min-width: 750px) and (max-width: 1079px) {
    .presha-brand-logos {
      padding: 36px 0 44px;
    }

    .presha-brand-logos__heading-wrap {
      padding: 0 32px;
      margin-bottom: 24px;
    }

    .presha-brand-logos__track {
      gap: 16px;
      padding: 8px 32px 16px;
    }

    .presha-brand-logos__card {
      width: 180px;
      height: 120px;
      padding: 18px;
    }
  }

  /* ── Mobile (under 750px) ────────────────────────────────────────────────── */
  @media screen and (max-width: 749px) {
    .presha-brand-logos {
      padding: 32px 0 40px;      /* CHANGE: mobile section padding             */
    }

    .presha-brand-logos__heading-wrap {
      margin-bottom: 20px;
      padding: 0 20px;
    }

    .presha-brand-logos__title {
      font-size: 20px;           /* CHANGE: mobile heading size                */
    }

    .presha-brand-logos__track {
      gap: 12px;                 /* CHANGE: mobile gap between cards           */
      padding: 6px 20px 14px;
    }

    .presha-brand-logos__card {
      width: 150px;              /* CHANGE: mobile card width                  */
      height: 105px;             /* CHANGE: mobile card height                 */
      padding: 16px;
      border-radius: 10px;
    }

    .presha-brand-logos__brand-name {
      font-size: 12px;           /* CHANGE: mobile text fallback size          */
    }

    .presha-brand-logos__img {
      max-height: 40px;          /* CHANGE: mobile logo max height             */
      max-width: 110px;
    }
  }

  /* ── Reduced motion ──────────────────────────────────────────────────────── */
  /* Respects user's OS-level "reduce motion" preference                        */
  @media (prefers-reduced-motion: reduce) {
    .presha-brand-logos__card {
      transition: box-shadow 0.1s ease;
      transform: none !important;
    }
  }

{% endstylesheet %}

{%- comment -%}
  ============================================================================
  GSAP ANIMATION
  ============================================================================
  - Heading: fades in + slides up when section enters viewport
  - Cards: stagger fade in + slide up, landing at full opacity
  - Graceful fallback: if GSAP isn't loaded, items show immediately
  - ScrollTrigger fires once (no replay on scroll back)

  CHANGE: duration/ease/stagger values below to adjust animation feel
  CHANGE: scrollTrigger.start to adjust when animation triggers
  ============================================================================
{%- endcomment -%}
<script>
(function () {
  var sectionEl = document.getElementById('presha-brand-logos-{{ section.id }}');
  if (!sectionEl) return;

  var headingWrap = sectionEl.querySelector('.presha-brand-logos__heading-wrap');
  var cards = sectionEl.querySelectorAll('.presha-brand-logos__card');

  /* ── Fallback if GSAP/ScrollTrigger not loaded ── */
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
    if (headingWrap) headingWrap.style.opacity = '1';
    cards.forEach(function (el) { el.style.opacity = '1'; });
    return;
  }

  /* ── Heading entrance: fade + slide up ── */
  gsap.fromTo(headingWrap,
    { opacity: 0, y: 18 },
    {
      opacity: 1,
      y: 0,
      duration: 0.65,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: sectionEl,
        start: 'top 85%',         /* fires when section top hits 85% viewport */
        once: true
      }
    }
  );

  /* ── Cards entrance: stagger fade + slide up ── */
  gsap.fromTo(cards,
    { opacity: 0, y: 20 },
    {
      opacity: 1,                 /* cards rest at full opacity                */
      y: 0,
      duration: 0.45,
      ease: 'power2.out',
      stagger: 0.06,              /* delay between each card animation        */
      scrollTrigger: {
        trigger: sectionEl,
        start: 'top 80%',
        once: true
      }
    }
  );
}());
</script>

{%- comment -%}
  ============================================================================
  SCHEMA — Theme Editor Configuration
  ============================================================================
  SECTION SETTINGS:
  - eyebrow  → optional small text above heading (leave blank to hide)
  - heading  → main heading text

  BLOCK SETTINGS (per brand):
  - brand_name      → text label (used as fallback + aria-label)
  - logo_asset      → SVG filename in assets/ folder (e.g. "brand-nike.svg")
  - logo            → image picker for brand logo (overrides text)
  - collection_url  → link to the brand's collection page

  PRESETS:
  - Default brands pre-populated for quick setup
  - max_blocks: 12 — increase if you need more brand slots
  ============================================================================
{%- endcomment -%}
{% schema %}
{
  "name": "Brand Logos",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "info": "Small label above the heading. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "SHOP BY BRAND"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name",
          "info": "Displayed as bold text until a logo is provided.",
          "default": "Nike"
        },
        {
          "type": "text",
          "id": "logo_asset",
          "label": "Logo Asset Filename",
          "info": "SVG filename in assets/ folder (e.g. 'brand-nike.svg'). Takes priority over image picker."
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand Logo (optional)",
          "info": "Upload a black-on-transparent PNG or SVG. Max 400px wide. Used if no asset filename is set."
        },
        {
          "type": "url",
          "id": "collection_url",
          "label": "Collection URL",
          "info": "Links this brand to its collection page."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Logos",
      "settings": {
        "eyebrow": "AUTHENTICATED PARTNERSHIPS",
        "heading": "SHOP BY BRAND"
      },
      "blocks": [
        { "type": "brand", "settings": { "brand_name": "Nike", "logo_asset": "brand-nike.svg", "collection_url": "/collections/nike" } },
        { "type": "brand", "settings": { "brand_name": "Air Jordan", "logo_asset": "brand-air-jordan.svg", "collection_url": "/collections/jordan" } },
        { "type": "brand", "settings": { "brand_name": "Adidas", "logo_asset": "brand-adidas.svg", "collection_url": "/collections/adidas" } },
        { "type": "brand", "settings": { "brand_name": "Chrome Hearts", "logo_asset": "brand-chrome-hearts.svg", "collection_url": "/collections/chrome-hearts" } },
        { "type": "brand", "settings": { "brand_name": "Goyard", "logo_asset": "brand-goyard.svg", "collection_url": "/collections/goyard" } },
        { "type": "brand", "settings": { "brand_name": "New Balance", "logo_asset": "brand-new-balance.svg", "collection_url": "/collections/new-balance" } },
        { "type": "brand", "settings": { "brand_name": "On Running", "logo_asset": "brand-on-running.svg", "collection_url": "/collections/on-running" } },
        { "type": "brand", "settings": { "brand_name": "Yeezy", "logo_asset": "brand-yeezy.svg", "collection_url": "/collections/yeezy" } }
      ]
    }
  ]
}
{% endschema %}
