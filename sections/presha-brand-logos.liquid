{%- comment -%}
  PRESHA BRAND LOGOS — Shop By Brand / Featured Brands strip
  ─────────────────────────────────────────────────────────
  Desktop  : Horizontal flex row, logos space-evenly, opacity 0.7 → 1 on hover
  Mobile   : Horizontally scrollable row with scroll-snap
  Borders  : 1px solid #E2E2E2 top and bottom
  Padding  : 64px vertical (desktop), 40px (mobile)
  Logo height: max 40px, width auto
  Each brand block: image_picker (upload the real logo) + url (collection link)
  Falls back to inline SVG if no image uploaded.
  GSAP ScrollTrigger: section header fades in, logos stagger in from below.
{%- endcomment -%}

<section
  id="presha-brand-logos-{{ section.id }}"
  class="presha-brand-logos"
  aria-label="Shop by Brand"
>
  {%- comment -%} Section header eyebrow / label {%- endcomment -%}
  <div class="presha-brand-logos__header">
    <span class="presha-brand-logos__eyebrow">SHOP BY BRAND</span>
    <span class="presha-brand-logos__line" aria-hidden="true"></span>
  </div>

  <div class="presha-brand-logos__inner">
    <div class="presha-brand-logos__track" role="list">

      {%- for block in section.blocks -%}
        {%- if block.type == 'brand' -%}
          <a
            class="presha-brand-logos__item"
            href="{{ block.settings.collection_url | default: '#' }}"
            aria-label="Shop {{ block.settings.brand_name }}"
            role="listitem"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.logo != blank -%}
              {{
                block.settings.logo
                | image_url: width: 400
                | image_tag:
                  loading: 'lazy',
                  class: 'presha-brand-logos__img',
                  alt: block.settings.brand_name,
                  width: block.settings.logo.width,
                  height: block.settings.logo.height
              }}
            {%- else -%}
              {%- comment -%} Inline SVG fallbacks — replace once real logos are uploaded {%- endcomment -%}
              {%- case block.settings.brand_name -%}

                {%- when 'Jordan' -%}
                  {%- comment -%} Air Jordan Jumpman silhouette {%- endcomment -%}
                  <svg class="presha-brand-logos__svg" viewBox="0 0 80 90" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path fill="#111111" d="
                      M40,4 C43,4 46,6.5 46,10 C46,13.5 43,16 40,16 C37,16 34,13.5 34,10 C34,6.5 37,4 40,4 Z
                      M35,18 L45,18 C45,18 50,26 55,32 C59,37 68,30 70,32 C72,34 63,43 57,40
                      C53.5,38.5 50,48 47,55 L53,62 L60,80 L55,80 L49,65 L40,56
                      L31,65 L25,80 L20,80 L27,62 L33,55
                      C30,48 26.5,38.5 23,40 C17,43 8,34 10,32 C12,30 21,37 25,32
                      C30,26 35,18 35,18 Z
                    "/>
                  </svg>

                {%- when 'Nike' -%}
                  {%- comment -%} Nike Swoosh {%- endcomment -%}
                  <svg class="presha-brand-logos__svg" viewBox="0 0 200 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path fill="#111111" d="M6,54 C38,12 130,-2 194,28 C148,34 92,48 70,58 C52,66 40,74 26,66 C12,58 6,54 6,54 Z"/>
                  </svg>

                {%- when 'Adidas' -%}
                  {%- comment -%} Adidas three-stripe mountain logo + wordmark {%- endcomment -%}
                  <svg class="presha-brand-logos__svg" viewBox="0 0 130 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <polygon fill="#111111" points="65,8 94,60 36,60"/>
                    <rect fill="#111111" x="28" y="66" width="74" height="7" rx="1"/>
                    <text x="65" y="76" text-anchor="middle" font-family="Arial, sans-serif" font-weight="900" font-size="0" fill="#111111">adidas</text>
                    <!-- Three stripes overlaid on the triangle -->
                    <rect fill="#ffffff" x="51" y="36" width="5" height="20" transform="rotate(-30,53.5,46)"/>
                    <rect fill="#ffffff" x="62" y="28" width="5" height="28" transform="rotate(-30,64.5,42)"/>
                    <rect fill="#ffffff" x="73" y="20" width="5" height="36" transform="rotate(-30,75.5,38)"/>
                  </svg>

                {%- when 'New Balance' -%}
                  {%- comment -%} NB stacked wordmark {%- endcomment -%}
                  <svg class="presha-brand-logos__svg" viewBox="0 0 140 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <!-- N letterform -->
                    <path fill="#111111" d="M5,8 L5,52 L17,52 L17,26 L35,52 L47,52 L47,8 L35,8 L35,34 L17,8 Z"/>
                    <!-- B letterform -->
                    <path fill="#111111" d="M55,8 L55,52 L82,52 C91,52 98,46 98,38 C98,33 95,29 90,27 C94,25 97,21 97,16 C97,11 91,8 84,8 Z M67,18 L82,18 C85,18 87,20 87,23 C87,26 85,28 82,28 L67,28 Z M67,38 L67,43 L84,43 C87,43 89,41 89,40 C89,39 87,37 84,37 L67,37 Z"/>
                    <!-- "new balance" wordmark below -->
                    <text x="5" y="58" font-family="Arial, sans-serif" font-size="7" font-weight="700" letter-spacing="1.5" fill="#111111" text-transform="uppercase">NEW BALANCE</text>
                  </svg>

                {%- when 'Yeezy' -%}
                  {%- comment -%} YEEZY stark wordmark {%- endcomment -%}
                  <svg class="presha-brand-logos__svg" viewBox="0 0 200 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <text x="100" y="46" text-anchor="middle" font-family="Arial Black, 'Arial Bold', Gadget, sans-serif" font-weight="900" font-size="48" fill="#111111" letter-spacing="8">YEEZY</text>
                  </svg>

                {%- when 'Chrome Hearts' -%}
                  {%- comment -%} Chrome Hearts gothic cross + wordmark {%- endcomment -%}
                  <svg class="presha-brand-logos__svg" viewBox="0 0 220 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <!-- Gothic Cross -->
                    <path fill="#111111" d="
                      M18,16 L22,16 L22,10 C22,8 24,6 26,6 L30,6 C32,6 34,8 34,10 L34,16 L38,16 C40,16 42,18 42,20 L42,24 C42,26 40,28 38,28 L34,28 L34,46 C34,48 32,50 30,50 L26,50 C24,50 22,48 22,46 L22,28 L18,28 C16,28 14,26 14,24 L14,20 C14,18 16,16 18,16 Z
                    "/>
                    <!-- CH wordmark -->
                    <text x="56" y="36" font-family="Georgia, 'Times New Roman', serif" font-weight="700" font-size="22" fill="#111111" letter-spacing="0.5">CHROME</text>
                    <text x="56" y="58" font-family="Georgia, 'Times New Roman', serif" font-weight="700" font-size="22" fill="#111111" letter-spacing="0.5">HEARTS</text>
                  </svg>

                {%- when 'Goyard' -%}
                  {%- comment -%} Goyard stylised wordmark {%- endcomment -%}
                  <svg class="presha-brand-logos__svg" viewBox="0 0 200 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <text x="100" y="44" text-anchor="middle" font-family="Georgia, serif" font-weight="700" font-size="40" fill="#111111" letter-spacing="4">GOYARD</text>
                  </svg>

                {%- when 'Off-White' -%}
                  {%- comment -%} Off-White quoted wordmark {%- endcomment -%}
                  <svg class="presha-brand-logos__svg" viewBox="0 0 240 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <text x="120" y="44" text-anchor="middle" font-family="Arial Black, sans-serif" font-weight="900" font-size="28" fill="#111111" letter-spacing="2">&quot;OFF-WHITE™&quot;</text>
                  </svg>

                {%- when 'Asics' -%}
                  {%- comment -%} ASICS wordmark {%- endcomment -%}
                  <svg class="presha-brand-logos__svg" viewBox="0 0 180 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <text x="90" y="46" text-anchor="middle" font-family="Arial Black, sans-serif" font-weight="900" font-size="46" fill="#111111" letter-spacing="3">ASICS</text>
                  </svg>

                {%- else -%}
                  {%- comment -%} Generic text fallback for any other brand {%- endcomment -%}
                  <svg class="presha-brand-logos__svg" viewBox="0 0 200 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <text x="50%" y="55%" text-anchor="middle" dominant-baseline="middle"
                      font-family="Arial Black, sans-serif" font-weight="900" font-size="26"
                      fill="#111111" letter-spacing="2">
                      {{ block.settings.brand_name | upcase | truncate: 14, '' }}
                    </text>
                  </svg>
              {%- endcase -%}
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</section>

{% stylesheet %}

  /* ─── Section wrapper ──────────────────────────────────────────── */
  .presha-brand-logos {
    width: 100%;
    background-color: #ffffff;
    border-top: 1px solid #E2E2E2;
    border-bottom: 1px solid #E2E2E2;
    padding: 48px 0 64px;
    box-sizing: border-box;
    overflow: hidden;
  }

  /* ─── Section header / eyebrow ─────────────────────────────────── */
  .presha-brand-logos__header {
    display: flex;
    align-items: center;
    gap: 20px;
    max-width: 1280px;
    margin: 0 auto 44px;
    padding: 0 40px;
    opacity: 0; /* starting state — GSAP animates to 1 */
  }

  .presha-brand-logos__eyebrow {
    font-family: var(--font-body--family, 'Jost', system-ui, sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #888888;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .presha-brand-logos__line {
    flex: 1;
    height: 1px;
    background: #E2E2E2;
    display: block;
  }

  /* ─── Inner container ──────────────────────────────────────────── */
  .presha-brand-logos__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ─── Desktop: horizontal flex row ────────────────────────────── */
  .presha-brand-logos__track {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: nowrap;
  }

  .presha-brand-logos__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    text-decoration: none;
    opacity: 0; /* GSAP stagger start state */
    transition: opacity 0.35s ease, transform 0.35s ease, filter 0.35s ease;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    will-change: opacity, transform;
  }

  /* Hover: full opacity + subtle lift */
  .presha-brand-logos__item:hover,
  .presha-brand-logos__item:focus-visible {
    opacity: 1 !important;
    transform: translateY(-2px) scale(1.06);
    outline: none;
    filter: none;
  }

  /* ─── Logo images (uploaded via Theme Editor) ──────────────────── */
  .presha-brand-logos__img {
    display: block;
    max-height: 40px;
    width: auto;
    object-fit: contain;
    /* desaturate images to unify the look until real black-format logos are uploaded */
    filter: grayscale(100%);
    transition: filter 0.35s ease;
  }

  .presha-brand-logos__item:hover .presha-brand-logos__img,
  .presha-brand-logos__item:focus-visible .presha-brand-logos__img {
    filter: grayscale(0%);
  }

  /* ─── SVG fallback logos ───────────────────────────────────────── */
  .presha-brand-logos__svg {
    display: block;
    height: 38px;
    width: auto;
    max-width: 180px;
    flex-shrink: 0;
  }

  /* ─── Tablet: two-row wrap ─────────────────────────────────────── */
  @media screen and (min-width: 750px) and (max-width: 1023px) {
    .presha-brand-logos {
      padding: 40px 0 56px;
    }

    .presha-brand-logos__inner {
      padding: 0 24px;
    }

    .presha-brand-logos__header {
      padding: 0 24px;
      margin-bottom: 32px;
    }

    .presha-brand-logos__track {
      flex-wrap: wrap;
      justify-content: center;
      gap: 32px 48px;
    }

    .presha-brand-logos__item {
      flex: 0 0 calc(33% - 32px);
      justify-content: center;
    }
  }

  /* ─── Mobile: horizontal scroll with snap ──────────────────────── */
  @media screen and (max-width: 749px) {
    .presha-brand-logos {
      padding: 36px 0 44px;
    }

    .presha-brand-logos__header {
      padding: 0 20px;
      margin-bottom: 24px;
    }

    .presha-brand-logos__inner {
      padding: 0;
      overflow: hidden;
    }

    .presha-brand-logos__track {
      justify-content: flex-start;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding: 8px 20px 12px;
      gap: 16px;
      /* Hide scrollbar cosmetically */
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .presha-brand-logos__track::-webkit-scrollbar {
      display: none;
    }

    .presha-brand-logos__item {
      scroll-snap-align: center;
      flex: 0 0 auto;
      min-width: 80px;
    }

    .presha-brand-logos__img,
    .presha-brand-logos__svg {
      max-height: 30px;
    }
  }

  /* ─── Reduced motion ───────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .presha-brand-logos__item,
    .presha-brand-logos__item:hover {
      transition: opacity 0.1s ease;
      transform: none !important;
    }
  }

{% endstylesheet %}

<script>
(function() {
  /* ── GSAP ScrollTrigger entrance animation ── */
  /* Guard: GSAP + ScrollTrigger must be loaded (in theme.liquid) */
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
    /* Fallback: make everything visible immediately */
    var sectionEl = document.getElementById('presha-brand-logos-{{ section.id }}');
    if (!sectionEl) return;
    sectionEl.querySelectorAll('.presha-brand-logos__header, .presha-brand-logos__item').forEach(function(el) {
      el.style.opacity = '1';
    });
    return;
  }

  var sectionEl = document.getElementById('presha-brand-logos-{{ section.id }}');
  if (!sectionEl) return;

  var header  = sectionEl.querySelector('.presha-brand-logos__header');
  var items   = sectionEl.querySelectorAll('.presha-brand-logos__item');

  /* Register ScrollTrigger if not already registered */
  if (!ScrollTrigger.isRegistered) {
    gsap.registerPlugin(ScrollTrigger);
  }

  /* 1. Eyebrow header fades in */
  gsap.fromTo(header,
    { opacity: 0, y: 16 },
    {
      opacity: 1,
      y: 0,
      duration: 0.7,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: sectionEl,
        start: 'top 85%',
        once: true
      }
    }
  );

  /* 2. Logo items stagger in from below */
  gsap.fromTo(items,
    { opacity: 0, y: 24 },
    {
      opacity: 0.7, /* resting opacity = 0.7 per spec */
      y: 0,
      duration: 0.55,
      ease: 'power2.out',
      stagger: 0.08,
      scrollTrigger: {
        trigger: sectionEl,
        start: 'top 80%',
        once: true
      }
    }
  );
})();
</script>

{% schema %}
{
  "name": "Brand Logos",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name",
          "info": "Used for alt text and SVG fallback if no logo image is uploaded.",
          "default": "Nike"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand Logo",
          "info": "Upload a black PNG or SVG logo. Recommended: transparent background, max 400px wide."
        },
        {
          "type": "url",
          "id": "collection_url",
          "label": "Collection URL",
          "info": "Link this logo to a brand collection page."
        }
      ]
    }
  ],
  "presets": [
    {
