{%- comment -%}
  ============================================================
  PRESHA MARQUEE — Infinite Scrolling Trust Strip
  Uses the same proven technique as the password page marquee.
  ============================================================
{%- endcomment -%}

<div class="pm-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="pm-track">
    {%- comment -%}
      We render 4 copies of the same items so the scrolling strip
      always appears full — no matter how wide the screen is.
      The CSS animation translates -25% per loop (= one copy).
    {%- endcomment -%}
    <div class="pm-inner" style="animation-duration: {{ section.settings.speed }}s;">
      {%- assign copies = "1,2,3,4" | split: "," -%}
      {%- for copy in copies -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'item' -%}
            <span class="pm-item">{{ block.settings.text }}</span>
            <span class="pm-sep" aria-hidden="true">•</span>
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  /* ── Full-width section strip ──────────────────────────── */
  .pm-section {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    overflow: hidden;
    padding: 20px 0;    /* ← EDIT: strip height */
  }

  /* ── Outer clip container ─────────────────────────────── */
  .pm-track {
    overflow: hidden;
    white-space: nowrap;
  }

  /* ── Scrolling inner row ─────────────────────────────────
     IMPORTANT: display must be inline-flex for the animation
     to work correctly. Do not change this.                  */
  .pm-inner {
    display: inline-flex;
    align-items: center;
    gap: 0;
    will-change: transform;
    animation: pmScroll linear infinite;
    /* duration is set inline from section settings */
  }

  /* ── Pause on hover ──────────────────────────────────────
     Remove this rule to keep scrolling even on hover.       */
  .pm-section:hover .pm-inner {
    animation-play-state: paused;
  }

  /* ── Text items ──────────────────────────────────────────
     font-size:     ← EDIT e.g. 12px, 14px, 16px
     font-weight:   ← EDIT 400=normal 700=bold 900=black
     letter-spacing:← EDIT e.g. 0.08em, 0.15em, 0.2em
     color:         ← EDIT text colour
     padding:       ← EDIT left/right breathing room          */
  .pm-item {
    display: inline-block;
    font-family: var(--font-body--family, system-ui, sans-serif);
    font-size: 13px;          /* ← EDIT text size */
    font-weight: 700;         /* ← EDIT text weight */
    letter-spacing: 0.12em;   /* ← EDIT letter spacing */
    text-transform: uppercase;
    color: #ffffff;           /* ← EDIT text colour */
    padding: 0 28px;          /* ← EDIT space around each phrase */
    white-space: nowrap;
  }

  /* ── Bullet ──────────────────────────────────────────────
     font-size: match to .pm-item for visual alignment
     opacity:   0=invisible 1=full                           */
  .pm-sep {
    display: inline-block;
    flex-shrink: 0;
    font-size: 10px;    /* ← EDIT bullet size */
    color: #ffffff;     /* ← EDIT bullet colour */
    opacity: 0.4;       /* ← EDIT bullet visibility */
  }

  /* ── Keyframe ────────────────────────────────────────────
     We use 4 copies → translate 25% = one copy scrolls out.
     DO NOT change the 25% value if you keep 4 copies.      */
  @keyframes pmScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-25%); }
  }

  /* ── Reduced motion ──────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .pm-inner { animation: none; }
  }

  /* ── Mobile ──────────────────────────────────────────── */
  @media screen and (max-width: 749px) {
    .pm-section { padding: 14px 0; } /* ← EDIT mobile strip height */
    .pm-item {
      font-size: 12px;   /* ← EDIT mobile text size */
      padding: 0 18px;   /* ← EDIT mobile phrase spacing */
    }
  }
</style>

<script>
  // GSAP ScrollTrigger entrance — delete this block if not needed
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
    gsap.registerPlugin(ScrollTrigger);
    var el = document.querySelector('.pm-section');
    if (!el) return;
    gsap.from(el, {
      opacity: 0,
      y: 10,             // ← EDIT slide distance (px)
      duration: 0.6,     // ← EDIT entrance speed (seconds)
      ease: 'power2.out',
      scrollTrigger: { trigger: el, start: 'top 95%', once: true }
    });
  });
</script>

{% schema %}
{
  "name": "Presha Marquee",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#111827"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (lower = faster)",
      "min": 10,
      "max": 120,
      "step": 5,
      "unit": "s",
      "default": 30,
      "info": "Duration in seconds for one full loop. 15 = fast, 60 = slow."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Marquee Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "MARQUEE ITEM"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Presha Marquee",
      "blocks": [
        { "type": "item", "settings": { "text": "PRESHA VERIFIED AUTHENTICITY" } },
        { "type": "item", "settings": { "text": "WORLDWIDE SHIPPING" } },
        { "type": "item", "settings": { "text": "TRUSTED GLOBAL RESALE PLATFORM" } },
        { "type": "item", "settings": { "text": "LUXURY STREETWEAR" } }
      ]
    }
  ]
}
{% endschema %}
