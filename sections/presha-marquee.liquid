{%- comment -%}
  PRESHA MARQUEE — JS-driven infinite scroll ticker
  Uses requestAnimationFrame for guaranteed cross-browser scrolling.
{%- endcomment -%}

<div id="preshaMarqueeSection-{{ section.id }}" class="presha-marquee-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="presha-marquee-clip">
    <div id="preshaMarqueeTrack-{{ section.id }}" class="presha-marquee-row">
      {%- for block in section.blocks -%}
        {%- if block.type == 'item' -%}
          <span class="presha-marquee-item" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </span>
          <span class="presha-marquee-bullet" aria-hidden="true">&nbsp;•&nbsp;</span>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  /* Full-width section bleed */
  .presha-marquee-section {
    position: relative;
    width: 100vw;
    left: 50%;
    margin-left: -50vw;
    padding: 18px 0;    /* ← EDIT: strip height */
    overflow: hidden;
  }

  .presha-marquee-clip {
    overflow: hidden;
    width: 100%;
  }

  /* The scrolling row — JS moves this via translateX */
  .presha-marquee-row {
    display: inline-flex;
    white-space: nowrap;
    align-items: center;
    will-change: transform;
  }

  /* Text items */
  .presha-marquee-item {
    display: inline-block;
    font-family: var(--font-body--family, system-ui, sans-serif);
    font-size: 13px;          /* ← EDIT: text size */
    font-weight: 700;         /* ← EDIT: text weight */
    letter-spacing: 0.12em;   /* ← EDIT: letter spacing */
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
    padding: 0 24px;          /* ← EDIT: spacing per phrase */
  }

  .presha-marquee-bullet {
    display: inline-block;
    color: {{ section.settings.text_color }};
    opacity: 0.4;
    font-size: 10px;
  }

  @media screen and (max-width: 749px) {
    .presha-marquee-section { padding: 14px 0; }
    .presha-marquee-item {
      font-size: 12px;   /* ← EDIT: mobile text size */
      padding: 0 16px;
    }
  }
</style>

<script>
(function() {
  var speed = {{ section.settings.speed }};   // px per second — higher = faster
  var sectionEl = document.getElementById('preshaMarqueeSection-{{ section.id }}');
  var track = document.getElementById('preshaMarqueeTrack-{{ section.id }}');

  if (!sectionEl || !track) return;

  // Clone the row so it loops seamlessly
  var clone = track.cloneNode(true);
  clone.removeAttribute('id');
  clone.setAttribute('aria-hidden', 'true');
  track.parentNode.appendChild(clone);

  // Wrap both in a flex container so they sit side by side
  var wrapper = document.createElement('div');
  wrapper.style.cssText = 'display:flex; width:max-content; will-change:transform;';
  track.parentNode.insertBefore(wrapper, track);
  wrapper.appendChild(track);
  wrapper.appendChild(clone);

  var offset = 0;
  var trackWidth = 0;
  var paused = false;
  var lastTime = null;

  function getTrackWidth() {
    trackWidth = track.offsetWidth;
  }

  function step(timestamp) {
    if (!lastTime) lastTime = timestamp;
    var delta = (timestamp - lastTime) / 1000; // seconds
    lastTime = timestamp;

    if (!paused && trackWidth > 0) {
      offset += speed * delta;
      if (offset >= trackWidth) {
        offset -= trackWidth;
      }
      wrapper.style.transform = 'translateX(-' + offset + 'px)';
    }

    requestAnimationFrame(step);
  }

  // Pause on hover
  sectionEl.addEventListener('mouseenter', function() { paused = true; });
  sectionEl.addEventListener('mouseleave', function() { paused = false; lastTime = null; });

  // Respect reduced motion preference
  if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    return;
  }

  // Wait for fonts to load before measuring
  document.fonts ? document.fonts.ready.then(function() {
    getTrackWidth();
    requestAnimationFrame(step);
  }) : (getTrackWidth(), requestAnimationFrame(step));

})();
</script>

{% schema %}
{
  "name": "Scrolling Marquee",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (px per second)",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 80,
      "info": "Higher = faster scroll. 80 is a good default."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Marquee Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "MARQUEE ITEM"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling Marquee",
      "blocks": [
        { "type": "item", "settings": { "text": "PRESHA VERIFIED AUTHENTICITY" } },
        { "type": "item", "settings": { "text": "WORLDWIDE SHIPPING" } },
        { "type": "item", "settings": { "text": "TRUSTED GLOBAL RESALE PLATFORM" } },
        { "type": "item", "settings": { "text": "LUXURY STREETWEAR" } }
      ]
    }
  ]
}
{% endschema %}
