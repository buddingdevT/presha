{%- comment -%}
  PRESHA MARQUEE - CSS-driven infinite scroll ticker.
  The content is rendered twice so translateX(-50%) loops seamlessly.
{%- endcomment -%}

{%- assign animation_duration = 1000 | divided_by: section.settings.speed | at_least: 8 -%}

<div
  id="preshaMarqueeSection-{{ section.id }}"
  class="presha-marquee-section"
  style="
    --presha-marquee-bg: {{ section.settings.bg_color }};
    --presha-marquee-text: {{ section.settings.text_color }};
    --presha-marquee-duration: {{ animation_duration }}s;
  "
>
  <div class="presha-marquee-clip">
    <div class="presha-marquee-track">
      {%- for copy_index in (1..2) -%}
        <div class="presha-marquee-row"{% if copy_index == 2 %} aria-hidden="true"{% endif %}>
          {%- for block in section.blocks -%}
            {%- if block.type == 'item' -%}
              <span class="presha-marquee-item" {% if copy_index == 1 %}{{ block.shopify_attributes }}{% endif %}>
                {{ block.settings.text }}
              </span>
              <span class="presha-marquee-bullet" aria-hidden="true">&nbsp;&middot;&nbsp;</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
    overflow: visible;
  }

  .presha-marquee-section {
    position: relative;
    width: 100vw;
    left: 50%;
    margin-left: -50vw;
    padding: 18px 0;
    overflow: hidden;
    background-color: var(--presha-marquee-bg);
  }

  .presha-marquee-clip {
    overflow: hidden;
    width: 100%;
  }

  .presha-marquee-track {
    display: flex;
    width: max-content;
    will-change: transform;
    animation: presha-marquee-scroll var(--presha-marquee-duration) linear infinite;
  }

  .presha-marquee-row {
    display: inline-flex;
    white-space: nowrap;
    align-items: center;
    min-width: max-content;
  }

  .presha-marquee-item {
    display: inline-block;
    font-family: 'Gilroy', var(--font-body--family, 'Jost', system-ui, sans-serif);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--presha-marquee-text);
    padding: 0 24px;
  }

  .presha-marquee-bullet {
    display: inline-block;
    color: var(--presha-marquee-text);
    opacity: 0.4;
    font-size: 10px;
  }

  @keyframes presha-marquee-scroll {
    from {
      transform: translate3d(0, 0, 0);
    }

    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @media (hover: hover) {
    .presha-marquee-section:hover .presha-marquee-track {
      animation-play-state: paused;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .presha-marquee-track {
      animation: none;
      transform: none;
    }
  }

  @media screen and (max-width: 749px) {
    .presha-marquee-section {
      padding: 14px 0;
    }

    .presha-marquee-item {
      font-size: 12px;
      padding: 0 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Scrolling Marquee",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (px per second)",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 80,
      "info": "Higher = faster scroll. 80 is a good default."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Marquee Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "MARQUEE ITEM"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling Marquee",
      "blocks": [
        { "type": "item", "settings": { "text": "PRESHA VERIFIED AUTHENTICITY" } },
        { "type": "item", "settings": { "text": "WORLDWIDE SHIPPING" } },
        { "type": "item", "settings": { "text": "TRUSTED GLOBAL RESALE PLATFORM" } },
        { "type": "item", "settings": { "text": "LUXURY STREETWEAR" } }
      ]
    }
  ]
}
{% endschema %}
