{%- comment -%}
  PRESHA GIFTS FOR HER / HIM — Editorial Split Tiles
  Two side-by-side lifestyle image tiles with hover zoom.
{%- endcomment -%}

{{ 'section-presha-gifts.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #presha-gifts-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_vertical }}px;
    padding-bottom: {{ section.settings.padding_vertical }}px;
  }
{%- endstyle -%}

<section class="presha-gifts" id="presha-gifts-{{ section.id }}">
  <div class="presha-gifts__container">
    <div class="presha-gifts__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}"
           class="presha-gifts__tile"
           {{ block.shopify_attributes }}>

          {%- if block.settings.image != blank -%}
            <img class="presha-gifts__img"
                 src="{{ block.settings.image | image_url: width: 1200 }}"
                 srcset="{{ block.settings.image | image_url: width: 480 }} 480w,
                         {{ block.settings.image | image_url: width: 720 }} 720w,
                         {{ block.settings.image | image_url: width: 960 }} 960w,
                         {{ block.settings.image | image_url: width: 1200 }} 1200w"
                 sizes="(max-width: 749px) 100vw, 50vw"
                 alt="{{ block.settings.heading | escape }}"
                 loading="lazy"
                 width="960" height="1200">
          {%- else -%}
            <div class="presha-gifts__placeholder">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'presha-gifts__placeholder-svg' }}
            </div>
          {%- endif -%}

          <div class="presha-gifts__overlay"></div>

          <div class="presha-gifts__content">
            {%- if block.settings.eyebrow != blank -%}
              <span class="presha-gifts__eyebrow">{{ block.settings.eyebrow }}</span>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h3 class="presha-gifts__heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.button_text != blank -%}
              <span class="presha-gifts__btn">{{ block.settings.button_text }}</span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
    gsap.registerPlugin(ScrollTrigger);

    const sectionId = '{{ section.id }}';
    const section = document.querySelector('#presha-gifts-' + sectionId);
    if (!section) return;

    const tiles = section.querySelectorAll('.presha-gifts__tile');

    gsap.from(tiles, {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      stagger: 0.15,
      scrollTrigger: {
        trigger: section,
        start: 'top 85%',
        once: true
      }
    });
  });
</script>

{% schema %}
{
  "name": "Gifts For Her / Him",
  "tag": "section",
  "class": "presha-gifts-section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Vertical Padding (Top & Bottom)",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "gift_tile",
      "name": "Gift Tile",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow Text",
          "default": "FIND HER PERFECT GIFT"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Gifts for Her"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gifts For Her / Him",
      "blocks": [
        {
          "type": "gift_tile",
          "settings": {
            "eyebrow": "FIND HER PERFECT GIFT",
            "heading": "Gifts for Her",
            "button_text": "SHOP NOW"
          }
        },
        {
          "type": "gift_tile",
          "settings": {
            "eyebrow": "FIND HIS PERFECT PAIR",
            "heading": "Gifts for Him",
            "button_text": "SHOP NOW"
          }
        }
      ]
    }
  ]
}
{% endschema %}
