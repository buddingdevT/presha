<section class="presha-trust-bar">
  <div class="presha-trust-container">
    {% for block in section.blocks %}
      <div class="presha-trust-item" {{ block.shopify_attributes }}>
        <div class="presha-trust-diamond-wrap">
          <div class="presha-trust-diamond">
            <div class="presha-trust-icon">
              {% case block.settings.icon %}
                {% when 'shield' %}
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>
                {% when 'globe' %}
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                {% when 'support' %}
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><circle cx="12" cy="13" r="3"></circle><path d="M12 10v-.5"></path></svg>
              {% endcase %}
            </div>
          </div>
        </div>
        <h3 class="presha-trust-heading">{{ block.settings.heading }}</h3>
        <p class="presha-trust-subtext">{{ block.settings.subtext }}</p>
      </div>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .presha-trust-bar {
    width: 100%;
    background-color: #ffffff;
    padding: 80px 20px;
    font-family: var(--font-body--family, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif);
  }
  .presha-trust-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: 40px;
  }
  .presha-trust-item {
    flex: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .presha-trust-diamond-wrap {
    margin-bottom: 24px;
    padding: 16px; 
  }
  .presha-trust-diamond {
    width: 68px;
    height: 68px;
    background-color: #6d001a;
    border-radius: 16px;
    transform: rotate(45deg);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 12px 24px rgba(109, 0, 26, 0.15);
  }
  .presha-trust-icon {
    transform: rotate(-45deg);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .presha-trust-heading {
    font-style: italic;
    font-weight: 800;
    text-transform: uppercase;
    font-size: 20px;
    letter-spacing: -0.01em;
    color: #000000;
    margin: 0 0 12px 0;
    line-height: 1.1;
  }
  .presha-trust-subtext {
    font-size: 14px;
    color: rgba(0,0,0,0.6);
    line-height: 1.6;
    margin: 0;
    max-width: 320px;
  }

  @media screen and (max-width: 768px) {
    .presha-trust-bar {
      padding: 60px 20px;
    }
    .presha-trust-container {
      flex-direction: column;
      gap: 50px;
    }
    .presha-trust-diamond-wrap {
      margin-bottom: 20px;
    }
    .presha-trust-heading {
      font-size: 18px;
    }
    .presha-trust-subtext {
      font-size: 13px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Authenticity Shield" },
            { "value": "globe", "label": "Global Shipping" },
            { "value": "support", "label": "Exclusive Support" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "AUTHENTICITY GUARANTEED"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Subtext",
          "default": "Every piece in our collection is 100% authentic and verified by experts."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "shield",
            "heading": "AUTHENTICITY GUARANTEED",
            "subtext": "Every piece in our collection is 100% authentic and verified by experts."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "globe",
            "heading": "GLOBAL SHIPPING",
            "subtext": "Luxury streetwear delivered to your doorstep, anywhere in the world."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "support",
            "heading": "EXCLUSIVE SUPPORT",
            "subtext": "24/7 concierge service for our community members and VIP clients."
          }
        }
      ]
    }
  ]
}
{% endschema %}
