<section class="presha-contact-page" aria-labelledby="PreshaContactTitle-{{ section.id }}">
  <div class="presha-contact-page__hero">
    <div class="presha-contact-page__hero-inner">
      <div class="presha-contact-page__hero-copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="presha-contact-page__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        <h1 id="PreshaContactTitle-{{ section.id }}" class="presha-contact-page__title">
          {{ section.settings.title | default: page.title }}
        </h1>

        {%- if section.settings.intro != blank -%}
          <div class="presha-contact-page__intro rte">
            {{ section.settings.intro }}
          </div>
        {%- endif -%}
      </div>

      <div class="presha-contact-page__hero-panel">
        <p class="presha-contact-page__panel-label">{{ section.settings.panel_label }}</p>
        <h2 class="presha-contact-page__panel-title">{{ section.settings.panel_title }}</h2>
        <p class="presha-contact-page__panel-text">{{ section.settings.panel_text }}</p>
        <div class="presha-contact-page__panel-meta">
          <span class="presha-contact-page__panel-pill">{{ section.settings.panel_pill_one }}</span>
          <span class="presha-contact-page__panel-pill">{{ section.settings.panel_pill_two }}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="presha-contact-page__content">
    <div class="presha-contact-page__content-inner">
      <div class="presha-contact-page__info-column">
        <div class="presha-contact-page__info-block">
          <p class="presha-contact-page__section-eyebrow">{{ section.settings.info_eyebrow }}</p>
          <h2 class="presha-contact-page__section-title">{{ section.settings.info_title }}</h2>
          {%- if section.settings.info_text != blank -%}
            <div class="presha-contact-page__info-text rte">
              {{ section.settings.info_text }}
            </div>
          {%- endif -%}
        </div>

        <div class="presha-contact-page__cards">
          {%- for block in section.blocks -%}
            <article class="presha-contact-page__card" {{ block.shopify_attributes }}>
              <p class="presha-contact-page__card-label">{{ block.settings.label }}</p>
              <h3 class="presha-contact-page__card-title">{{ block.settings.title }}</h3>
              {%- if block.settings.text != blank -%}
                <p class="presha-contact-page__card-text">{{ block.settings.text }}</p>
              {%- endif -%}
              {%- if block.settings.link_label != blank -%}
                <a {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %} class="presha-contact-page__card-link">
                  {{ block.settings.link_label }}
                </a>
              {%- endif -%}
            </article>
          {%- endfor -%}
        </div>

        {%- if page.content != blank -%}
          <div class="presha-contact-page__editorial rte">
            {{ page.content }}
          </div>
        {%- endif -%}
      </div>

      <div class="presha-contact-page__form-shell">
        <div class="presha-contact-page__form-header">
          <p class="presha-contact-page__section-eyebrow">{{ section.settings.form_eyebrow }}</p>
          <h2 class="presha-contact-page__section-title">{{ section.settings.form_title }}</h2>
          <p class="presha-contact-page__form-text">{{ section.settings.form_text }}</p>
        </div>

        {%- form 'contact', class: 'presha-contact-page__form', id: 'PreshaContactForm' -%}
          <input type="hidden" name="contact[tags]" value="contact-page,presha-contact">

          {%- if form.posted_successfully? -%}
            <div class="presha-contact-page__alert presha-contact-page__alert--success" tabindex="-1" autofocus>
              {{ section.settings.success_message }}
            </div>
          {%- elsif form.errors -%}
            <div class="presha-contact-page__alert presha-contact-page__alert--error" tabindex="-1" autofocus>
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="presha-contact-page__field-grid">
            <div class="presha-contact-page__field">
              <label class="presha-contact-page__label" for="PreshaContactName-{{ section.id }}">Full name</label>
              <input id="PreshaContactName-{{ section.id }}" class="presha-contact-page__input" type="text" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" autocomplete="name">
            </div>

            <div class="presha-contact-page__field">
              <label class="presha-contact-page__label" for="PreshaContactEmail-{{ section.id }}">Email address</label>
              <input id="PreshaContactEmail-{{ section.id }}" class="presha-contact-page__input" type="email" name="contact[email]" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" autocomplete="email" autocorrect="off" autocapitalize="off" required>
            </div>

            <div class="presha-contact-page__field">
              <label class="presha-contact-page__label" for="PreshaContactPhone-{{ section.id }}">Phone number</label>
              <input id="PreshaContactPhone-{{ section.id }}" class="presha-contact-page__input" type="tel" name="contact[phone]" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" autocomplete="tel">
            </div>

            <div class="presha-contact-page__field">
              <label class="presha-contact-page__label" for="PreshaContactOrder-{{ section.id }}">Order number</label>
              <input id="PreshaContactOrder-{{ section.id }}" class="presha-contact-page__input" type="text" name="contact[order_number]">
            </div>
          </div>

          <div class="presha-contact-page__field">
            <label class="presha-contact-page__label" for="PreshaContactTopic-{{ section.id }}">Topic</label>
            <select id="PreshaContactTopic-{{ section.id }}" class="presha-contact-page__input presha-contact-page__select" name="contact[topic]">
              <option value="General enquiry">General enquiry</option>
              <option value="Order support">Order support</option>
              <option value="Shipping question">Shipping question</option>
              <option value="Returns and refunds">Returns and refunds</option>
              <option value="Authentication question">Authentication question</option>
            </select>
          </div>

          <div class="presha-contact-page__field">
            <label class="presha-contact-page__label" for="PreshaContactBody-{{ section.id }}">Message</label>
            <textarea id="PreshaContactBody-{{ section.id }}" class="presha-contact-page__textarea" name="contact[body]" rows="7" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>

          <div class="presha-contact-page__actions">
            <button type="submit" class="presha-contact-page__submit">{{ section.settings.button_label }}</button>
            <p class="presha-contact-page__privacy-note">{{ section.settings.privacy_note }}</p>
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .presha-contact-page { background: #f5f1ec; color: #000000; }
  .presha-contact-page__hero { padding: 88px 0 40px; }
  .presha-contact-page__hero-inner, .presha-contact-page__content-inner { width: min(100% - 32px, 1200px); margin: 0 auto; }
  .presha-contact-page__hero-inner, .presha-contact-page__content-inner, .presha-contact-page__info-column, .presha-contact-page__cards, .presha-contact-page__form, .presha-contact-page__field, .presha-contact-page__actions { display: grid; gap: 24px; }
  .presha-contact-page__hero-copy, .presha-contact-page__hero-panel, .presha-contact-page__form-shell, .presha-contact-page__card, .presha-contact-page__editorial { border: 1px solid #ddd9d3; border-radius: 8px; background: #ffffff; }
  .presha-contact-page__hero-copy { padding: 28px 24px; }
  .presha-contact-page__hero-panel { padding: 24px; background: linear-gradient(180deg, rgba(109,0,26,0.08) 0%, rgba(109,0,26,0.02) 100%), #ffffff; }
  .presha-contact-page__eyebrow, .presha-contact-page__section-eyebrow, .presha-contact-page__card-label, .presha-contact-page__panel-label { margin: 0 0 12px; color: #6d001a; font-family: 'Gilroy', var(--font-body--family, 'Jost', Arial, sans-serif); font-size: 11px; font-weight: 700; letter-spacing: 0.18em; line-height: 1.2; text-transform: uppercase; }
  .presha-contact-page__title { margin: 0; font-family: 'The Glamore', var(--font-heading--family, 'Cormorant Garamond', Georgia, serif); font-size: 42px; font-weight: 400; line-height: 0.96; letter-spacing: -0.03em; text-wrap: balance; }
  .presha-contact-page__intro, .presha-contact-page__info-text, .presha-contact-page__editorial, .presha-contact-page__form-text, .presha-contact-page__privacy-note, .presha-contact-page__card-text, .presha-contact-page__panel-text { font-family: 'Gilroy', var(--font-body--family, 'Jost', Arial, sans-serif); font-size: 16px; line-height: 1.7; color: #4a4a4a; }
  .presha-contact-page__intro { margin-top: 24px; max-width: 56rem; }
  .presha-contact-page__panel-title, .presha-contact-page__section-title { margin: 0; font-family: 'Gilroy', var(--font-body--family, 'Jost', Arial, sans-serif); font-size: 28px; font-weight: 800; letter-spacing: -0.03em; line-height: 1.04; text-transform: uppercase; }
  .presha-contact-page__panel-text, .presha-contact-page__form-text { margin: 14px 0 0; }
  .presha-contact-page__panel-meta { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; }
  .presha-contact-page__panel-pill { display: inline-flex; align-items: center; min-height: 38px; padding: 8px 16px; border-radius: 9999px; background: rgba(109,0,26,0.08); color: #6d001a; font-family: 'Gilroy', var(--font-body--family, 'Jost', Arial, sans-serif); font-size: 12px; font-weight: 700; letter-spacing: 0.1em; line-height: 1; text-transform: uppercase; }
  .presha-contact-page__content { padding: 0 0 88px; }
  .presha-contact-page__info-column { gap: 20px; align-content: start; }
  .presha-contact-page__cards { gap: 16px; }
  .presha-contact-page__card { padding: 22px 20px; }
  .presha-contact-page__card-title { margin: 0; font-family: 'Gilroy', var(--font-body--family, 'Jost', Arial, sans-serif); font-size: 18px; font-weight: 700; line-height: 1.25; color: #000000; }
  .presha-contact-page__card-text { margin: 10px 0 0; }
  .presha-contact-page__card-link { display: inline-flex; margin-top: 14px; color: #6d001a; font-family: 'Gilroy', var(--font-body--family, 'Jost', Arial, sans-serif); font-size: 13px; font-weight: 700; letter-spacing: 0.08em; line-height: 1.3; text-decoration: none; text-transform: uppercase; }
  .presha-contact-page__card-link:hover { color: #580015; }
  .presha-contact-page__editorial { padding: 22px 20px; }
  .presha-contact-page__editorial :is(p, ul, ol):first-child { margin-top: 0; }
  .presha-contact-page__editorial :is(p, ul, ol):last-child { margin-bottom: 0; }
  .presha-contact-page__form-shell { padding: 24px 20px; }
  .presha-contact-page__form-header { margin-bottom: 24px; }
  .presha-contact-page__form { gap: 18px; }
  .presha-contact-page__field-grid { display: grid; gap: 16px; }
  .presha-contact-page__field { gap: 8px; }
  .presha-contact-page__label { font-family: 'Gilroy', var(--font-body--family, 'Jost', Arial, sans-serif); font-size: 13px; font-weight: 700; letter-spacing: 0.06em; line-height: 1.3; text-transform: uppercase; color: #000000; }
  .presha-contact-page__input, .presha-contact-page__textarea { width: 100%; min-height: 52px; padding: 14px 18px; border: 1.5px solid #b8b3ac; border-radius: 20px; background: #ffffff; color: #000000; font-family: 'Gilroy', var(--font-body--family, 'Jost', Arial, sans-serif); font-size: 16px; line-height: 1.4; transition: border-color 0.22s ease, box-shadow 0.22s ease; }
  .presha-contact-page__textarea { min-height: 180px; resize: vertical; border-radius: 24px; }
  .presha-contact-page__input:focus, .presha-contact-page__textarea:focus { outline: none; border-color: #6d001a; box-shadow: 0 0 0 4px rgba(109,0,26,0.12); }
  .presha-contact-page__select { appearance: none; background-image: linear-gradient(45deg, transparent 50%, #6d001a 50%), linear-gradient(135deg, #6d001a 50%, transparent 50%); background-position: calc(100% - 22px) calc(50% - 3px), calc(100% - 16px) calc(50% - 3px); background-size: 6px 6px, 6px 6px; background-repeat: no-repeat; padding-right: 42px; }
  .presha-contact-page__actions { gap: 14px; margin-top: 4px; }
  .presha-contact-page__submit { min-height: 50px; width: 100%; padding: 14px 24px; border: 0; border-radius: 9999px; background: #6d001a; color: #ffffff; font-family: 'Gilroy', var(--font-body--family, 'Jost', Arial, sans-serif); font-size: 13px; font-weight: 700; letter-spacing: 0.1em; line-height: 1; text-transform: uppercase; cursor: pointer; transition: background-color 0.22s ease, transform 0.22s ease; }
  .presha-contact-page__submit:hover { background: #580015; transform: translateY(-1px); }
  .presha-contact-page__privacy-note { margin: 0; font-size: 14px; }
  .presha-contact-page__alert { padding: 14px 16px; border-radius: 8px; font-family: 'Gilroy', var(--font-body--family, 'Jost', Arial, sans-serif); font-size: 14px; line-height: 1.6; }
  .presha-contact-page__alert--success { background: #ebf5f0; color: #1e6b3f; border: 1px solid rgba(30,107,63,0.18); }
  .presha-contact-page__alert--error { background: #fceaec; color: #b8001a; border: 1px solid rgba(184,0,26,0.16); }
  .presha-contact-page__alert a, .presha-contact-page__intro a, .presha-contact-page__info-text a, .presha-contact-page__editorial a { color: #6d001a; text-underline-offset: 0.18em; }
  .presha-contact-page__intro :is(p, ul, ol), .presha-contact-page__info-text :is(p, ul, ol) { margin-top: 0; }
  .presha-contact-page__intro :is(p, ul, ol):last-child, .presha-contact-page__info-text :is(p, ul, ol):last-child { margin-bottom: 0; }
  @media screen and (min-width: 750px) {
    .presha-contact-page__hero { padding: 104px 0 48px; }
    .presha-contact-page__hero-copy { padding: 40px 36px; }
    .presha-contact-page__hero-panel, .presha-contact-page__form-shell { padding: 32px; }
    .presha-contact-page__field-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .presha-contact-page__title { font-size: 64px; }
  }
  @media screen and (min-width: 1024px) {
    .presha-contact-page__hero-inner { grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr); align-items: stretch; }
    .presha-contact-page__content-inner { grid-template-columns: minmax(320px, 0.85fr) minmax(0, 1.15fr); align-items: start; }
    .presha-contact-page__cards { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .presha-contact-page__title { font-size: 78px; }
    .presha-contact-page__section-title, .presha-contact-page__panel-title { font-size: 34px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Presha Contact Page",
  "tag": "section",
  "class": "presha-contact-page-wrapper",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Contact" },
    { "type": "text", "id": "title", "label": "Title", "default": "Talk To Presha" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>Questions about an order, authentication, delivery or a product you are considering? Reach out and the Presha team will guide you directly.</p>" },
    { "type": "text", "id": "panel_label", "label": "Panel label", "default": "Direct support" },
    { "type": "text", "id": "panel_title", "label": "Panel title", "default": "Fast answers for serious buyers" },
    { "type": "textarea", "id": "panel_text", "label": "Panel text", "default": "Use the form for product questions, order support, authentication enquiries and post-purchase issues. The more detail you send, the faster we can help." },
    { "type": "text", "id": "panel_pill_one", "label": "Panel pill one", "default": "Dubai-based" },
    { "type": "text", "id": "panel_pill_two", "label": "Panel pill two", "default": "Luxury resale support" },
    { "type": "text", "id": "info_eyebrow", "label": "Info eyebrow", "default": "Support details" },
    { "type": "text", "id": "info_title", "label": "Info title", "default": "How we can help" },
    { "type": "richtext", "id": "info_text", "label": "Info text", "default": "<p>For the fastest reply, include your order number where relevant and tell us exactly what you need. We can help before purchase, after delivery and during authentication-related enquiries.</p>" },
    { "type": "text", "id": "form_eyebrow", "label": "Form eyebrow", "default": "Send a message" },
    { "type": "text", "id": "form_title", "label": "Form title", "default": "Contact Presha" },
    { "type": "textarea", "id": "form_text", "label": "Form text", "default": "Share your details below and we will review your enquiry as quickly as possible." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Send Message" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Your message has been sent. Presha will be in touch soon." },
    { "type": "textarea", "id": "privacy_note", "label": "Privacy note", "default": "By sending a message, you agree to let Presha Trends use your details to respond to your enquiry and support your request." }
  ],
  "blocks": [
    {
      "type": "support_card",
      "name": "Support card",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Email" },
        { "type": "text", "id": "title", "label": "Title", "default": "preshatrends@gmail.com" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Use this for product questions, order support and general enquiries." },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Email Presha" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Presha Contact Page",
      "blocks": [
        { "type": "support_card", "settings": { "label": "Email", "title": "preshatrends@gmail.com", "text": "Use this for product questions, order support and general enquiries.", "link_label": "Email Presha", "link": "mailto:preshatrends@gmail.com" } },
        { "type": "support_card", "settings": { "label": "Order support", "title": "Include your order number", "text": "Add your order reference, item name and issue details so we can help faster." } },
        { "type": "support_card", "settings": { "label": "Authentication", "title": "Ask before you buy", "text": "If you need clarity on a product or our verification process, send the item name and your question." } },
        { "type": "support_card", "settings": { "label": "Response focus", "title": "Clear details get faster replies", "text": "The more context you share, the easier it is for the team to respond precisely." } }
      ]
    }
  ]
}
{% endschema %}
