{%- comment -%}
  ============================================================================
  PRESHA FEATURED CATEGORIES
  ============================================================================
  Design ref: User-provided "Featured Categories" image
  - Italic serif heading "Featured Categories" left-aligned
  - Horizontal row of tall/portrait lifestyle photo cards
  - Each card: rounded corners, category name below in sans-serif
  - Scrollable on all viewports (4+ cards visible on desktop)
  - GSAP ScrollTrigger: heading fades in, cards stagger up
  - Each card links to a Shopify collection
  - Image uploaded via Theme Editor per block

  POSITION: After Presha Authentication section
  ============================================================================
{%- endcomment -%}

<section
  id="presha-featured-categories-{{ section.id }}"
  class="presha-fcats"
  aria-label="Featured Categories"
>

  {%- comment -%} ── Heading ── {%- endcomment -%}
  <div class="presha-fcats__heading-wrap">
    <h2 class="presha-fcats__title">{{ section.settings.heading }}</h2>
  </div>

  {%- comment -%} ── Category card row ── {%- endcomment -%}
  <div class="presha-fcats__track-wrap">
    <div class="presha-fcats__track" role="list">

      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {%- assign category_title = block.settings.category_name | default: block.settings.collection.title | default: 'Category' -%}
          <a
            class="presha-fcats__card"
            href="{{ block.settings.collection.url | default: '#' }}"
            aria-label="Shop {{ category_title }}"
            role="listitem"
            {{ block.shopify_attributes }}
          >
            <div class="presha-fcats__card-img-wrap">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    class: 'presha-fcats__card-img',
                    alt: category_title,
                    sizes: '(max-width: 749px) 55vw, (max-width: 1079px) 30vw, 280px'
                }}
              {%- else -%}
                {%- comment -%} Placeholder gradient — replaced once image is uploaded {%- endcomment -%}
                <div class="presha-fcats__card-placeholder">
                  <svg class="presha-fcats__placeholder-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2" stroke="#bbb" stroke-width="1.5"/>
                    <circle cx="8.5" cy="8.5" r="1.5" fill="#bbb"/>
                    <path d="M3 16l5-5 4 4 3-3 6 6" stroke="#bbb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              {%- endif -%}

              {%- comment -%} Glassmorphism Overlay on Hover {%- endcomment -%}
              <div class="presha-fcats__glass-overlay"></div>
            </div>
            <div class="presha-fcats__card-info">
              {%- comment -%} 
                Editorial Index Numbers — Commented out per user request to keep the UI minimal. 
                <span class="presha-fcats__card-index">0{{ forloop.index }}</span>
              {%- endcomment -%}
              <span class="presha-fcats__card-label">{{ category_title }}</span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</section>

{% stylesheet %}

  /* ── Section wrapper ─────────────────────────────────────────── */
  .presha-fcats {
    width: 100%;
    background-color: #ffffff;
    /* Fit viewport logic: constrained padding using vh */
    padding: 6vh 0 8vh !important; 
    min-height: calc(100vh - var(--header-height, 72px));
    display: flex;
    flex-direction: column;
    justify-content: center;
    box-sizing: border-box;
    overflow: hidden;
  }

  /* ── Heading — Aligned with Trending Now (1280px / 20px) ─────── */
  .presha-fcats__heading-wrap {
    max-width: 1280px !important; /* Standard site width */
    margin: 0 auto 32px !important; 
    padding: 0 20px !important; /* Standard site padding */
    opacity: 0; 
    will-change: opacity, transform;
    text-align: left !important;
    width: 100%;
  }

  .presha-fcats__title {
    font-family: var(--font-heading-family, 'Cormorant Garamond', serif) !important;
    font-size: clamp(28px, 4vw, 42px) !important;
    font-weight: 800 !important;
    font-style: italic !important;
    color: #1a1a1a !important;
    margin: 0 !important;
    line-height: 1 !important;
    letter-spacing: -0.01em !important;
    text-transform: uppercase !important;
    text-align: left !important;
  }

  /* ── Track wrap — constrains viewport overflow ───────────────── */
  .presha-fcats__track-wrap {
    max-width: 100vw;
    margin: 0;
    padding: 0;
    overflow: visible;
  }

  /* ── Card track — Horizontal Scroll aligned with site padding ── */
  .presha-fcats__track {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 28px; 
    flex-wrap: nowrap;
    overflow-x: auto;
    overflow-y: visible;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    /* Padding-left matches the heading's 20px standard */
    padding: 20px 20px 60px !important; 
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .presha-fcats__track::-webkit-scrollbar {
    display: none;
  }

  /* ── Category card ───────────────────────────────────────────── */
  .presha-fcats__card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    flex-shrink: 0;
    scroll-snap-align: center;
    text-decoration: none;
    width: clamp(240px, 20vw, 320px);
    opacity: 0; 
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    will-change: opacity, transform;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Staggered Rhythm — Every even card offset downwards */
  .presha-fcats__card:nth-child(even) {
    margin-top: 40px;
  }

  .presha-fcats__card:hover {
    transform: translateY(-8px);
  }

  /* ── Card image wrapper ──────────────────────────────────────── */
  .presha-fcats__card-img-wrap {
    width: 100%;
    aspect-ratio: 3 / 4.2;
    border-radius: 12px; /* Radius-LG */
    overflow: hidden;
    background: #F5F1EC; /* Soft Ivory placeholder */
    position: relative;
    border: 1px solid rgba(109, 0, 26, 0.05); /* Subtle burgundy printed edge */
  }

  /* Glassmorphism Overlay */
  .presha-fcats__glass-overlay {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0);
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 2;
    pointer-events: none;
  }

  .presha-fcats__card:hover .presha-fcats__glass-overlay {
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(2.5px);
    -webkit-backdrop-filter: blur(2.5px);
  }

  .presha-fcats__card-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Internal cinematic zoom on hover */
  .presha-fcats__card:hover .presha-fcats__card-img {
    transform: scale(1.08);
  }

  /* ── Card Info & Typography ──────────────────────────────────── */
  .presha-fcats__card-info {
    display: flex;
    flex-direction: column;
    margin-top: 20px;
    position: relative;
    width: 100%;
  }

  .presha-fcats__card-index {
    font-family: var(--font-body-family, 'Gilroy', sans-serif);
    font-size: 10px;
    font-weight: 600;
    color: rgba(0,0,0,0.3);
    letter-spacing: 0.1em;
    margin-bottom: 4px;
    transition: color 0.3s ease;
  }

  .presha-fcats__card-label {
    display: inline-block;
    font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
    font-size: clamp(20px, 2vw, 28px);
    font-weight: 500;
    font-style: italic; /* Display Font Editorial Mandate */
    color: #1a1a1a;
    letter-spacing: -0.01em;
    line-height: 1.1;
    transition: color 0.3s ease;
    position: relative;
    padding-bottom: 4px;
  }

  /* Burgundy Sweep Hover Effect */
  .presha-fcats__card-label::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1.5px;
    background-color: #6D001A;
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .presha-fcats__card:hover .presha-fcats__card-label {
    color: #6D001A;
  }

  .presha-fcats__card:hover .presha-fcats__card-index {
    color: #6D001A;
  }

  .presha-fcats__card:hover .presha-fcats__card-label::after {
    width: 100%;
  }

  /* ── Tablet ──────────────────────────────────────────────────── */
  @media screen and (min-width: 750px) and (max-width: 1079px) {
    .presha-fcats {
      padding: 48px 0 56px;
    }
    .presha-fcats__track {
      gap: 24px;
      padding: 20px 8vw 40px;
    }
    .presha-fcats__card {
      width: 240px;
    }
  }

  /* ── Mobile ──────────────────────────────────────────────────── */
  @media screen and (max-width: 749px) {
    .presha-fcats {
      padding: 60px 0 80px;
    }
    .presha-fcats__track {
      padding: 10px 40px 40px;
      gap: 20px;
    }
    .presha-fcats__card {
      width: 200px;
    }
    .presha-fcats__card:nth-child(even) {
      margin-top: 24px;
    }
    .presha-fcats__card-label {
      font-size: 20px;
    }
  }

{% endstylesheet %}

<script>
(function () {
  var sectionEl = document.getElementById('presha-featured-categories-{{ section.id }}');
  if (!sectionEl) return;

  var headingWrap = sectionEl.querySelector('.presha-fcats__heading-wrap');
  var cards = sectionEl.querySelectorAll('.presha-fcats__card');

  /* Fallback if GSAP not loaded */
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
    if (headingWrap) headingWrap.style.opacity = '1';
    cards.forEach(function (el) { el.style.opacity = '1'; });
    return;
  }

  /* Heading entrance */
  gsap.fromTo(headingWrap,
    { opacity: 0, y: 16 },
    {
      opacity: 1,
      y: 0,
      duration: 0.65,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: sectionEl,
        start: 'top 85%',
        once: true
      }
    }
  );

  /* Cards stagger in */
  gsap.fromTo(cards,
    { opacity: 0, y: 28 },
    {
      opacity: 1,
      y: 0,
      duration: 0.5,
      ease: 'power2.out',
      stagger: 0.09,
      scrollTrigger: {
        trigger: sectionEl,
        start: 'top 80%',
        once: true
      }
    }
  );
}());
</script>

{% schema %}
{
  "name": "Featured Categories",
  "tag": "section",
  "class": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Categories"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "category_name",
          "label": "Category Name",
          "info": "Optional override for the collection title."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image",
          "info": "Upload a lifestyle photo. Portrait (3:4) works best. Recommended: min 800px wide."
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection",
          "info": "Links this card to a collection page."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Categories",
      "settings": {
        "heading": "Featured Categories"
      },
      "blocks": [
        { "type": "category", "settings": { "category_name": "Prada" } },
        { "type": "category", "settings": { "category_name": "Casablanca" } },
        { "type": "category", "settings": { "category_name": "Hermès" } },
        { "type": "category", "settings": { "category_name": "Enfants Riches Déprimés" } },
        { "type": "category", "settings": { "category_name": "Goyard" } },
        { "type": "category", "settings": { "category_name": "Louis Vuitton" } },
        { "type": "category", "settings": { "category_name": "Burberry" } },
        { "type": "category", "settings": { "category_name": "Fear Of God" } }
      ]
    }
  ]
}
{% endschema %}
