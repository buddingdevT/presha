{%- comment -%}
  ============================================================================
  PRESHA FEATURED CATEGORIES
  ============================================================================
  Design ref: User-provided "Featured Categories" image
  - Italic serif heading "Featured Categories" left-aligned
  - Horizontal row of tall/portrait lifestyle photo cards
  - Each card: rounded corners, category name below in sans-serif
  - Scrollable on all viewports (4+ cards visible on desktop)
  - GSAP ScrollTrigger: heading fades in, cards stagger up
  - Each card links to a Shopify collection
  - Image uploaded via Theme Editor per block

  POSITION: After Presha Authentication section
  ============================================================================
{%- endcomment -%}

<section
  id="presha-featured-categories-{{ section.id }}"
  class="presha-fcats"
  aria-label="Featured Categories"
>

  {%- comment -%} ── Heading ── {%- endcomment -%}
  <div class="presha-fcats__heading-wrap">
    <h2 class="presha-fcats__title">{{ section.settings.heading }}</h2>
  </div>

  {%- comment -%} ── Category card row ── {%- endcomment -%}
  <div class="presha-fcats__track-wrap">
    <div class="presha-fcats__track" role="list">

      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {%- assign category_title = block.settings.category_name | default: block.settings.collection.title | default: 'Category' -%}
          <a
            class="presha-fcats__card"
            href="{{ block.settings.collection.url | default: '#' }}"
            aria-label="Shop {{ category_title }}"
            role="listitem"
            {{ block.shopify_attributes }}
          >
            <div class="presha-fcats__card-img-wrap">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    class: 'presha-fcats__card-img',
                    alt: category_title,
                    sizes: '(max-width: 749px) 55vw, (max-width: 1079px) 30vw, 280px'
                }}
              {%- else -%}
                {%- comment -%} Placeholder gradient — replaced once image is uploaded {%- endcomment -%}
                <div class="presha-fcats__card-placeholder">
                  <svg class="presha-fcats__placeholder-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2" stroke="#bbb" stroke-width="1.5"/>
                    <circle cx="8.5" cy="8.5" r="1.5" fill="#bbb"/>
                    <path d="M3 16l5-5 4 4 3-3 6 6" stroke="#bbb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>
            <span class="presha-fcats__card-label">{{ category_title }}</span>
          </a>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</section>

{% stylesheet %}

  /* ── Section wrapper ─────────────────────────────────────────── */
  .presha-fcats {
    width: 100%;
    background-color: #ffffff;
    padding: 64px 0 72px;
    box-sizing: border-box;
    overflow: hidden;
  }

  /* ── Heading — italic serif, left-aligned ────────────────────── */
  .presha-fcats__heading-wrap {
    max-width: 1380px;
    margin: 0 auto 36px;
    padding: 0 40px;
    opacity: 0; /* GSAP animates to 1 */
    will-change: opacity, transform;
  }

  .presha-fcats__title {
    font-family: 'Cormorant Garamond', var(--font-heading--family, Georgia), serif;
    font-size: clamp(26px, 3vw, 38px);
    font-weight: 600;
    font-style: italic;
    color: #1a1a1a;
    margin: 0;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  /* ── Track wrap — constrains viewport overflow ───────────────── */
  .presha-fcats__track-wrap {
    max-width: 1380px;
    margin: 0 auto;
    padding: 0;
    overflow: hidden;
  }

  /* ── Card track — horizontal scroll ──────────────────────────── */
  .presha-fcats__track {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 20px;
    flex-wrap: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 4px 40px 8px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .presha-fcats__track::-webkit-scrollbar {
    display: none;
  }

  /* ── Category card ───────────────────────────────────────────── */
  .presha-fcats__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    scroll-snap-align: start;
    text-decoration: none;
    width: 260px;
    opacity: 0; /* GSAP stagger start */
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    will-change: opacity, transform;
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .presha-fcats__card:hover {
    transform: translateY(-4px);
  }

  /* ── Card image wrapper — portrait aspect ratio ──────────────── */
  .presha-fcats__card-img-wrap {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 12px;
    overflow: hidden;
    background: #f5f5f5;
    position: relative;
  }

  .presha-fcats__card-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .presha-fcats__card:hover .presha-fcats__card-img {
    transform: scale(1.04);
  }

  /* ── Placeholder (when no image uploaded) ────────────────────── */
  .presha-fcats__card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, #e8e8e8 0%, #d4d4d4 100%);
  }

  /* ── Card label — below the image ────────────────────────────── */
  .presha-fcats__card-label {
    display: block;
    width: 100%;
    text-align: center;
    margin-top: 14px;
    font-family: var(--font-body--family, 'Jost', system-ui, sans-serif);
    font-size: 15px;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: 0.01em;
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .presha-fcats__card:hover .presha-fcats__card-label {
    color: #6B1A2A; /* burgundy on hover */
  }

  /* ── Tablet ──────────────────────────────────────────────────── */
  @media screen and (min-width: 750px) and (max-width: 1079px) {
    .presha-fcats {
      padding: 48px 0 56px;
    }

    .presha-fcats__heading-wrap {
      padding: 0 32px;
      margin-bottom: 28px;
    }

    .presha-fcats__track {
      gap: 16px;
      padding: 4px 32px 8px;
    }

    .presha-fcats__card {
      width: 220px;
    }
  }

  /* ── Mobile ──────────────────────────────────────────────────── */
  @media screen and (max-width: 749px) {
    .presha-fcats {
      padding: 40px 0 48px;
    }

    .presha-fcats__heading-wrap {
      padding: 0 20px;
      margin-bottom: 24px;
    }

    .presha-fcats__title {
      font-size: 24px;
    }

    .presha-fcats__track {
      gap: 14px;
      padding: 4px 20px 8px;
    }

    .presha-fcats__card {
      width: 180px;
    }

    .presha-fcats__card-img-wrap {
      border-radius: 10px;
    }

    .presha-fcats__card-label {
      font-size: 13px;
      margin-top: 10px;
    }
  }

  /* ── Reduced motion ──────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .presha-fcats__card {
      transition: none;
      transform: none !important;
    }
    .presha-fcats__card-img {
      transition: none;
      transform: none !important;
    }
  }

{% endstylesheet %}

<script>
(function () {
  var sectionEl = document.getElementById('presha-featured-categories-{{ section.id }}');
  if (!sectionEl) return;

  var headingWrap = sectionEl.querySelector('.presha-fcats__heading-wrap');
  var cards = sectionEl.querySelectorAll('.presha-fcats__card');

  /* Fallback if GSAP not loaded */
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
    if (headingWrap) headingWrap.style.opacity = '1';
    cards.forEach(function (el) { el.style.opacity = '1'; });
    return;
  }

  /* Heading entrance */
  gsap.fromTo(headingWrap,
    { opacity: 0, y: 16 },
    {
      opacity: 1,
      y: 0,
      duration: 0.65,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: sectionEl,
        start: 'top 85%',
        once: true
      }
    }
  );

  /* Cards stagger in */
  gsap.fromTo(cards,
    { opacity: 0, y: 28 },
    {
      opacity: 1,
      y: 0,
      duration: 0.5,
      ease: 'power2.out',
      stagger: 0.09,
      scrollTrigger: {
        trigger: sectionEl,
        start: 'top 80%',
        once: true
      }
    }
  );
}());
</script>

{% schema %}
{
  "name": "Featured Categories",
  "tag": "section",
  "class": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Categories"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "category_name",
          "label": "Category Name",
          "info": "Optional override for the collection title."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image",
          "info": "Upload a lifestyle photo. Portrait (3:4) works best. Recommended: min 800px wide."
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection",
          "info": "Links this card to a collection page."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Categories",
      "settings": {
        "heading": "Featured Categories"
      },
      "blocks": [
        { "type": "category", "settings": { "category_name": "Air Jordan", "collection": "jordan" } },
        { "type": "category", "settings": { "category_name": "Nike", "collection": "nike" } },
        { "type": "category", "settings": { "category_name": "On Running", "collection": "on-running" } },
        { "type": "category", "settings": { "category_name": "Onitsuka Tiger", "collection": "onitsuka-tiger" } },
        { "type": "category", "settings": { "category_name": "Adidas", "collection": "adidas" } },
        { "type": "category", "settings": { "category_name": "New Balance", "collection": "new-balance" } },
        { "type": "category", "settings": { "category_name": "Yeezy", "collection": "yeezy" } },
        { "type": "category", "settings": { "category_name": "Asics", "collection": "asics" } }
      ]
    }
  ]
}
{% endschema %}
