<section class="presha-auth" style="background-color: {{ section.settings.bg_color }};">
  <div class="presha-auth-container">
    
    <!-- Left: Image & Badge -->
    <div class="presha-auth-left">
      <div class="presha-auth-image-wrap">
        {%- if section.settings.image != blank -%}
          <img 
            src="{{ section.settings.image | image_url: width: 1000 }}" 
            alt="{{ section.settings.image.alt | escape }}" 
            class="presha-auth-image" 
            loading="lazy"
          >
        {%- else -%}
          <img src="{{ 'auth4.webp' | asset_url }}" alt="Presha Authentication" class="presha-auth-image" loading="lazy">
        {%- endif -%}

        <!-- Overlay Badge -->
        <div class="presha-auth-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="presha-auth-badge-icon">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <polyline points="9 12 11 14 15 10"></polyline>
          </svg>
          <span class="presha-auth-badge-text">100% GUARANTEED<br>AUTHENTIC</span>
        </div>
      </div>
    </div>

    <!-- Right: Text & Features -->
    <div class="presha-auth-right">
      <span class="presha-auth-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="presha-auth-heading">{{ section.settings.heading }}</h2>
      <div class="presha-auth-desc">{{ section.settings.description }}</div>

      <!-- Feature Blocks -->
      <div class="presha-auth-features">
        {% for block in section.blocks %}
          {% if block.type == 'feature' %}
            <div class="presha-auth-feature" {{ block.shopify_attributes }}>
              <div class="presha-auth-feature-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                  <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
              </div>
              <div class="presha-auth-feature-text">
                <h4 class="presha-auth-feature-title">{{ block.settings.title }}</h4>
                <p class="presha-auth-feature-subtext">{{ block.settings.subtext }}</p>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <!-- CTA Button -->
      {%- if section.settings.btn_label != blank -%}
        <div class="presha-auth-action">
          <a {% if section.settings.btn_link != blank %}href="{{ section.settings.btn_link }}"{% endif %} class="presha-auth-btn">
            {{ section.settings.btn_label }}
          </a>
        </div>
      {%- endif -%}
    </div>
    
  </div>
</section>

{% stylesheet %}
  .presha-auth {
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
    padding: 96px 20px;
    font-family: 'Gilroy', var(--font-body--family, 'Jost', system-ui, -apple-system, sans-serif);
    color: #f5f1ec;
    overflow: hidden;
    position: relative;
  }
  .presha-auth::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.12) 0%, rgba(0, 0, 0, 0) 42%),
      linear-gradient(180deg, rgba(245, 241, 236, 0.04) 0%, rgba(245, 241, 236, 0) 100%);
    pointer-events: none;
  }
  .presha-auth-container {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 60px;
    position: relative;
    z-index: 1;
  }

  /* Left Column */
  .presha-auth-left {
    flex: 1;
    display: flex;
    justify-content: flex-start;
  }
  .presha-auth-image-wrap {
    position: relative;
    width: 100%;
    max-width: 500px;
    aspect-ratio: 4 / 5;
    background-color: #0a0a0a;
    border-radius: 8px;
    overflow: visible;
    box-shadow: 0 24px 54px rgba(0, 0, 0, 0.28);
  }
  .presha-auth-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 8px;
  }

  /* Overlay Badge */
  .presha-auth-badge {
    position: absolute;
    right: -22px;
    bottom: 38px;
    background-color: #6d001a;
    padding: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.36);
    width: 168px;
    height: 168px;
    border-radius: 2px;
    transform: rotate(12deg);
  }
  .presha-auth-badge-icon {
    width: 34px;
    height: 34px;
    color: #ffffff;
    margin-bottom: 10px;
    transform: rotate(-12deg);
  }
  .presha-auth-badge-text {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: #ffffff;
    text-transform: uppercase;
    line-height: 1.45;
    transform: rotate(-12deg);
  }

  /* Right Column */
  .presha-auth-right {
    flex: 1.1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 20px 0;
  }
  .presha-auth-eyebrow {
    font-size: 11px;
    color: #6d001a;
    letter-spacing: 0.18em;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 14px;
    display: block;
  }
  .presha-auth-heading {
    margin: 0 0 22px 0;
    font-family: 'Gilroy', var(--font-body--family, 'Jost', system-ui, sans-serif);
    font-size: clamp(34px, 4.4vw, 58px);
    font-weight: 900;
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: #f5f1ec;
    text-transform: uppercase;
    text-wrap: balance;
  }
  .presha-auth-desc {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(245, 241, 236, 0.76);
    margin-bottom: 40px;
    max-width: 580px;
  }
  .presha-auth-desc p {
    margin: 0;
  }

  /* Features */
  .presha-auth-features {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 48px;
    border-top: 1px solid rgba(245, 241, 236, 0.12);
  }
  .presha-auth-feature {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 18px 0 20px;
    border-bottom: 1px solid rgba(245, 241, 236, 0.12);
  }
  .presha-auth-feature-icon {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    color: #6d001a;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(109, 0, 26, 0.42);
    border-radius: 9999px;
    background: rgba(109, 0, 26, 0.12);
  }
  .presha-auth-feature-icon svg {
    width: 19px;
    height: 19px;
  }
  .presha-auth-feature-text {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 2px;
  }
  .presha-auth-feature-title {
    margin: 0;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #f5f1ec;
    text-transform: uppercase;
    line-height: 1.35;
  }
  .presha-auth-feature-subtext {
    margin: 0;
    font-size: 14px;
    color: rgba(245, 241, 236, 0.62);
    line-height: 1.6;
  }

  /* Button */
  .presha-auth-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #6d001a;
    color: #ffffff;
    text-decoration: none;
    min-height: 50px;
    padding: 14px 28px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 9999px;
    transition: background-color 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
  }
  .presha-auth-btn:hover {
    background-color: #580015;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(109, 0, 26, 0.28);
  }

  /* Responsive Constraints */
  @media screen and (max-width: 989px) {
    .presha-auth-container {
      flex-direction: column;
      gap: 60px;
      align-items: flex-start;
    }
    .presha-auth-left {
      width: 100%;
      padding-right: 22px;
    }
    .presha-auth-image-wrap {
      max-width: 500px;
      aspect-ratio: 4 / 5;
    }
    .presha-auth-badge {
      right: -14px;
      bottom: 22px;
      width: 148px;
      height: 148px;
      padding: 18px;
    }
    .presha-auth-right {
      width: 100%;
    }
  }

  @media screen and (max-width: 749px) {
    .presha-auth {
      padding: 72px 20px 80px;
    }
    .presha-auth-container {
      gap: 44px;
    }
    .presha-auth-badge {
      right: 12px;
      bottom: 12px;
      width: 126px;
      height: 126px;
      padding: 14px;
      transform: rotate(10deg);
    }
    .presha-auth-badge-icon {
      width: 24px;
      height: 24px;
    }
    .presha-auth-badge-text {
      font-size: 9px;
      letter-spacing: 0.12em;
    }
    .presha-auth-heading {
      font-size: 34px;
    }
    .presha-auth-desc {
      margin-bottom: 32px;
      font-size: 15px;
    }
    .presha-auth-features {
      margin-bottom: 36px;
    }
    .presha-auth-feature {
      gap: 14px;
      padding: 16px 0 18px;
    }
    .presha-auth-feature-icon {
      width: 38px;
      height: 38px;
    }
    .presha-auth-feature-title {
      font-size: 12px;
    }
    .presha-auth-feature-subtext {
      font-size: 13px;
    }
    .presha-auth-btn {
      width: 100%;
      text-align: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Authentication",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#201416"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Featured Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "THE PRESHA PROMISE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PRESHA VERIFIED"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Every single item sold on Presha Trends undergoes a rigorous 10-point inspection by our team of expert authenticators. From the box labels to the microscopic stitching details, we ensure your investment is legitimate.</p>"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "LEARN ABOUT AUTHENTICATION"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "EXPERT MULTI-POINT INSPECTION"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Subtext",
          "default": "Thorough physical inspection by certified specialists."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Authentication Feature",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "EXPERT MULTI-POINT INSPECTION",
            "subtext": "Thorough physical inspection by certified specialists."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "BLOCKCHAIN VERIFICATION",
            "subtext": "Digital certificates of authenticity for select premium items."
          }
        }
      ]
    }
  ]
}
{% endschema %}
