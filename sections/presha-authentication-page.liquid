      "label": "Title",
      "default": "Presha Verified"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>At Presha Trends, every item must earn its place. We take authentication seriously because trust sits at the center of luxury resale.</p>"
    },
    {
      "type": "text",
      "id": "stamp_label",
      "label": "Stamp label",
      "default": "Guaranteed"
    },
    {
      "type": "text",
      "id": "stamp_subtext",
      "label": "Stamp subtext",
      "default": "Authentic"
    },
    {
      "type": "text",
      "id": "process_eyebrow",
      "label": "Process eyebrow",
      "default": "Our process"
    },
    {
      "type": "text",
      "id": "process_title",
      "label": "Process title",
      "default": "How we verify"
    },
    {
      "type": "text",
      "id": "assurance_eyebrow",
      "label": "Assurance eyebrow",
      "default": "Buy with confidence"
    },
    {
      "type": "text",
      "id": "assurance_title",
      "label": "Assurance title",
      "default": "What our authentication standard means"
    },
    {
      "type": "richtext",
      "id": "assurance_text",
      "label": "Assurance text",
      "default": "<p>We review products with a luxury resale mindset: condition, construction, branding, packaging and consistency all matter. If a product does not meet our authentication standard, it does not move forward to sale.</p><p>Where an item includes original packaging, accessories or identifying documents, we review those details alongside the product itself. Some items may also go through additional review where the category, rarity or sourcing path requires it.</p>"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact text",
      "default": "Still have questions about our verification process or a specific item?"
    },
    {
      "type": "text",
      "id": "contact_link_label",
      "label": "Contact button label",
      "default": "Contact Presha"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact button link"
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "10-point"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Inspection standard"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "A structured review process designed for premium resale."
        }
      ]
    },
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Step number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Initial intake"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>We begin with a structured review of the product, source and visible condition before the item moves deeper into our process.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Presha Auth Page",
      "blocks": [
        {
          "type": "highlight",
          "settings": {
            "value": "10-point",
            "title": "Inspection standard",
            "text": "A structured review process designed for premium resale."
          }
        },
        {
          "type": "highlight",
          "settings": {
            "value": "Dubai-based",
            "title": "Handled with care",
            "text": "Every item is reviewed with the level of scrutiny luxury customers expect."
          }
        },
        {
          "type": "highlight",
          "settings": {
            "value": "Presha Verified",
            "title": "Only approved stock goes live",
            "text": "If an item does not meet our standard, it does not reach the storefront."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "01",
            "title": "Initial intake",
            "text": "<p>We begin with a structured review of the product, source and visible condition before the item moves deeper into our process.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "02",
            "title": "Detail verification",
            "text": "<p>Our team checks construction details, branding, shape, materials, labels, hardware, packaging and finishing against known standards for the item and category.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "03",
