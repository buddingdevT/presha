<!-- ============================================================
  PRESHA COLLECTION COLLECTIBLES — Brand Row (Dark / Frosted Glass)

  Bespoke variant of the Brand Row layout designed specifically for
  Collectibles. Sits on a deep burgundy background (#6D001A) with
  dimensional frosted-glass product cards — communicating rarity and
  exclusivity.

  THEME EDITOR SETUP:
  - Set "Eyebrow" (small label above heading, e.g. "Rare & Collectible")
  - Set "Heading" (large italic Cormorant heading, e.g. "Collectibles")
  - Link a Collection — products pulled automatically up to Product Limit
  - Product Limit: 4–12 (step 2), default 8
  - "View All link" — optional manual URL override

  EMPTY STATE:
  - If no collection is linked or collection is empty, 4 placeholder
    cards render (aria-hidden) so the section is visible in Theme Editor.

  ADMIN TODOS:
  - Create a "Collectibles" collection in Shopify Admin
  - Add products (figures, pop art, limited editions, etc.)
  - Assign collection in Theme Editor
  - Optionally set a "View All" URL pointing to the collection page
============================================================ -->

<style>
  /* ── Section wrapper ── */
  .presha-col-col {
    background: #6D001A;
    padding: 60px 0;
  }
  .presha-col-col__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ── Header row: left (eyebrow + rule + heading) + right (view all) ── */
  .presha-col-col__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 32px;
  }

  /* ── Eyebrow ── */
  .presha-col-col__eyebrow {
    display: block;
    font-family: var(--font-body-family, 'Jost', sans-serif);
    font-size: 0.5625rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 8px;
  }

  /* ── Animated horizontal rule — white, width 0 → 40px via GSAP ── */
  .presha-col-col__rule {
    width: 0;           /* GSAP animates this to 40px on scroll */
    height: 1px;
    background: rgba(255, 255, 255, 0.22);
    margin-bottom: 10px;
    will-change: width;
  }

  /* ── Large editorial heading ── */
  .presha-col-col__heading {
    font-family: var(--font-heading-family, 'Cormorant Garamond', serif);
    font-size: clamp(2.75rem, 7vw, 5rem);
    font-style: italic;
    font-weight: 600;
    color: #F5F1EC;
    line-height: 0.9;
    margin: 0;
    /* clip-path start state — GSAP animates to inset(0%) */
    clip-path: inset(100% 0 0 0);
    will-change: clip-path;
  }

  /* ── View All link (right side of header) ── */
  .presha-col-col__view-all {
    font-family: var(--font-body-family, 'Jost', sans-serif);
    font-size: 0.5625rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    position: relative;
    padding-bottom: 2px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: 24px;
    align-self: flex-end;
    transition: color 0.2s ease;
  }
  /* Ivory sweep underline on hover */
  .presha-col-col__view-all::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.75);
    transition: width 0.3s ease;
  }
  .presha-col-col__view-all:hover,
  .presha-col-col__view-all:focus {
    color: rgba(255, 255, 255, 0.75);
  }
  .presha-col-col__view-all:hover::after,
  .presha-col-col__view-all:focus::after {
    width: 100%;
  }
  .presha-col-col__view-all:focus-visible {
    outline: 2px solid rgba(245, 241, 236, 0.8);
    outline-offset: 3px;
  }

  /* ── Horizontal scroll track ── */
  .presha-col-col__track {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    scrollbar-width: none;            /* Firefox */
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }
  .presha-col-col__track::-webkit-scrollbar {
    display: none;                    /* Chrome / Safari */
  }

  /* ── Scroll hint label ── */
  .presha-col-col__scroll-hint {
    display: block;
    margin-top: 12px;
    font-family: var(--font-body-family, 'Jost', sans-serif);
    font-size: 0.5rem;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.16);
    user-select: none;
  }

  /* ── Product card — frosted glass on burgundy ── */
  .presha-col-col__card {
    flex: 0 0 196px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    text-decoration: none;
    display: block;
    scroll-snap-align: start;
    /* Dimensional frosted glass — primary state */
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.26),
      rgba(255, 255, 255, 0.14)
    );
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    /* Hover state via transition */
    transition: transform 0.2s ease-out,
                background 0.2s ease-out,
                border-color 0.2s ease-out;
    will-change: transform;
    cursor: pointer;
    touch-action: manipulation;
  }
  .presha-col-col__card:hover {
    transform: translateY(-4px);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.32),
      rgba(255, 255, 255, 0.18)
    );
    border-color: rgba(255, 255, 255, 0.28);
  }
  .presha-col-col__card:focus-visible {
    outline: 2px solid rgba(245, 241, 236, 0.8);
    outline-offset: 3px;
  }

  /* ── Card image ── */
  .presha-col-col__card-img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
  }

  /* ── Placeholder image block (empty state / no image) ── */
  .presha-col-col__card-img-placeholder {
    width: 100%;
    height: 260px;
    background: rgba(255, 255, 255, 0.08);
    display: block;
  }

  /* ── Verified badge — ivory circle, top-left of image ── */
  .presha-col-col__verified {
    position: absolute;
    top: 10px;
    left: 10px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .presha-col-col__verified svg {
    width: 12px;
    height: 12px;
  }

  /* ── Card body ── */
  .presha-col-col__card-body {
    padding: 12px 12px 14px;
  }
  .presha-col-col__card-vendor {
    font-family: var(--font-body-family, 'Jost', sans-serif);
    font-size: 0.46875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 4px;
    line-height: 1;
  }
  .presha-col-col__card-name {
    font-family: var(--font-body-family, 'Jost', sans-serif);
    font-size: 0.625rem;
    font-weight: 600;
    color: #F5F1EC;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 6px;
    line-height: 1.2;
  }
  .presha-col-col__card-price {
    font-family: var(--font-body-family, 'Jost', sans-serif);
    font-size: 0.625rem;
    font-weight: 700;
    color: #FFFFFF;
    line-height: 1;
  }

  /* ── Mobile (≤ 749px) ── */
  @media (max-width: 749px) {
    .presha-col-col {
      padding: 48px 0 52px;
    }
    .presha-col-col__container {
      padding: 0 16px;
    }
    .presha-col-col__header {
      margin-bottom: 24px;
    }
    .presha-col-col__card {
      flex: 0 0 162px;
    }
    .presha-col-col__card-img,
    .presha-col-col__card-img-placeholder {
      height: 216px;
    }
  }

  /* ── Reduced motion — disable card hover transitions ── */
  @media (prefers-reduced-motion: reduce) {
    .presha-col-col__card {
      transition: none;
    }
    .presha-col-col__view-all::after {
      transition: none;
    }
  }
</style>

<section
  class="presha-col-col"
  id="presha-col-col-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="presha-collection-collectibles"
>
  <div class="presha-col-col__container">

    <!-- ── Section header ── -->
    <div class="presha-col-col__header">

      <!-- Left: eyebrow + animated rule + large heading -->
      <div>
        <span
          class="presha-col-col__eyebrow"
          id="col-col-eyebrow-{{ section.id }}"
        >
          {{- section.settings.eyebrow | default: 'Rare & Collectible' -}}
        </span>
        <div
          class="presha-col-col__rule"
          id="col-col-rule-{{ section.id }}"
          aria-hidden="true"
        ></div>
        <h2
          class="presha-col-col__heading"
          id="col-col-heading-{{ section.id }}"
        >
          {{- section.settings.collection.title | default: section.settings.heading | default: 'Collectibles' -}}
        </h2>
      </div>

      <!-- Right: View All — uses view_all_url if provided, else collection URL -->
      {%- assign view_all_href = '' -%}
      {%- if section.settings.view_all_url != blank -%}
        {%- assign view_all_href = section.settings.view_all_url -%}
      {%- elsif section.settings.collection != blank -%}
        {%- assign view_all_href = section.settings.collection.url -%}
      {%- endif -%}

      {%- if view_all_href != '' -%}
        <a
          href="{{ view_all_href }}"
          class="presha-col-col__view-all"
          aria-label="View all {{ section.settings.heading | default: 'Collectibles' | escape }} products"
        >
          View All
        </a>
      {%- endif -%}

    </div><!-- /.presha-col-col__header -->

    <!-- ── Horizontal scroll track ── -->
    <div class="presha-col-col__track" id="col-col-track-{{ section.id }}">

      {%- if section.settings.collection != blank -%}

        {%- assign products_to_show = section.settings.collection.products -%}

        {%- if products_to_show.size > 0 -%}

          {%- for product in products_to_show limit: section.settings.product_limit -%}
            <a
              href="{{ product.url }}"
              class="presha-col-col__card"
              aria-label="{{ product.title | escape }}"
            >
              <!-- Image -->
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 400 }}"
                  srcset="{{ product.featured_image | image_url: width: 280 }} 280w,
                          {{ product.featured_image | image_url: width: 400 }} 400w"
                  sizes="196px"
                  alt=""
                  loading="lazy"
                  width="196"
                  height="260"
                  class="presha-col-col__card-img"
                >
              {%- else -%}
                <div class="presha-col-col__card-img-placeholder" aria-hidden="true"></div>
              {%- endif -%}

              <!-- Verified badge -->
              <div class="presha-col-col__verified" role="img" aria-label="Presha Verified">
                <svg viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 6l3 3 5-5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>

              <!-- Card info -->
              <div class="presha-col-col__card-body">
                <div class="presha-col-col__card-vendor">{{ product.vendor | escape }}</div>
                <div class="presha-col-col__card-name">{{ product.title | escape }}</div>
                <div class="presha-col-col__card-price">{{ product.price | money }}</div>
              </div>
            </a>
          {%- endfor -%}

        {%- else -%}
          <!-- Collection linked but empty — placeholder cards for Theme Editor visibility -->
          {%- for i in (1..4) -%}
            <div class="presha-col-col__card" aria-hidden="true">
              <div class="presha-col-col__card-img-placeholder"></div>
              <div class="presha-col-col__verified">
                <svg viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 6l3 3 5-5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="presha-col-col__card-body">
                <div class="presha-col-col__card-vendor">Brand</div>
                <div class="presha-col-col__card-name">Product Name</div>
                <div class="presha-col-col__card-price">—</div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}

      {%- else -%}
        <!-- No collection set — 4 placeholder cards so section is visible in Theme Editor -->
        {%- for i in (1..4) -%}
          <div class="presha-col-col__card" aria-hidden="true">
            <div class="presha-col-col__card-img-placeholder"></div>
            <div class="presha-col-col__verified">
              <svg viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2 6l3 3 5-5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="presha-col-col__card-body">
              <div class="presha-col-col__card-vendor">Brand</div>
              <div class="presha-col-col__card-name">Product Name</div>
              <div class="presha-col-col__card-price">—</div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}

    </div><!-- /.presha-col-col__track -->

    <!-- Scroll hint — visible on mobile, decorative -->
    <span class="presha-col-col__scroll-hint" aria-hidden="true">← drag to explore</span>

  </div><!-- /.presha-col-col__container -->
</section>

<script>
(function () {
  'use strict';

  var sectionId = '{{ section.id }}';

  // Guard: GSAP + ScrollTrigger must be loaded globally in theme.liquid
  if (!window.gsap || !window.ScrollTrigger) return;

  // Respect prefers-reduced-motion — reset clip-path and bail out
  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reducedMotion) {
    var headingEl = document.getElementById('col-col-heading-' + sectionId);
    if (headingEl) headingEl.style.clipPath = 'inset(0% 0 0 0)';
    return;
  }

  gsap.registerPlugin(ScrollTrigger);

  var eyebrow = document.getElementById('col-col-eyebrow-' + sectionId);
  var rule    = document.getElementById('col-col-rule-' + sectionId);
  var heading = document.getElementById('col-col-heading-' + sectionId);
  var track   = document.getElementById('col-col-track-' + sectionId);
  var cards   = track ? track.querySelectorAll('.presha-col-col__card') : [];

  /* ── Drag to scroll functionality ── */
  if (track) {
    var isDown = false;
    var startX;
    var scrollLeft;
    var isDragging = false;

    track.addEventListener('mousedown', function (e) {
      isDown = true;
      isDragging = false;
      track.classList.add('is-dragging');
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });

    track.addEventListener('mouseleave', function () {
      isDown = false;
      track.classList.remove('is-dragging');
    });

    track.addEventListener('mouseup', function () {
      isDown = false;
      track.classList.remove('is-dragging');
    });

    track.addEventListener('mousemove', function (e) {
      if (!isDown) return;
      e.preventDefault();
      isDragging = true;
      var x = e.pageX - track.offsetLeft;
      var walk = (x - startX) * 2;
      track.scrollLeft = scrollLeft - walk;
    });

    var links = track.querySelectorAll('a');
    links.forEach(function(link) {
      link.addEventListener('click', function(e) {
        if (isDragging) {
          e.preventDefault();
        }
      });
    });
  }

  if (!eyebrow || !rule || !heading) return;

  var tl = gsap.timeline({
    scrollTrigger: {
      trigger: '#presha-col-col-' + sectionId,
      start: 'top 80%',
      once: true
    }
  });

  // 1. Eyebrow fades up
  tl.fromTo(eyebrow,
    { opacity: 0, y: 12 },
    { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }
  );

  // 2. White rule animates in — width 0 → 40px
  tl.fromTo(rule,
    { width: 0 },
    { width: 40, duration: 0.35, ease: 'power2.inOut' },
    '-=0.2'
  );

  // 3. Heading clips up from below — editorial reveal
  tl.fromTo(heading,
    { clipPath: 'inset(100% 0 0 0)' },
    { clipPath: 'inset(0% 0 0 0)', duration: 0.7, ease: 'power3.out' },
    '-=0.25'
  );

  // 4. Cards stagger in
  if (cards.length > 0) {
    tl.fromTo(cards,
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.5, stagger: 0.07, ease: 'power2.out' },
      '-=0.3'
    );
  }
})();
</script>

{% schema %}
{
  "name": "Collection D",
  "tag": "div",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Rare & Collectible",
      "info": "Small uppercase label above the heading (e.g. 'Limited Edition', 'Rare & Collectible')"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Collectibles",
      "info": "Large italic editorial heading — the visual centrepiece of the section"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Products are pulled directly from this collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Number of products",
      "min": 4,
      "max": 12,
      "step": 2,
      "default": 8,
      "info": "Maximum products to display in the scroll row"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View All link (optional)",
      "info": "Override the default collection URL. If blank, the linked collection URL is used."
    }
  ],
  "presets": [
    {
      "name": "Collection D",
      "settings": {
        "eyebrow": "Rare & Collectible",
        "heading": "Collectibles"
      }
    }
  ]
}
{% endschema %}
