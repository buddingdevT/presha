      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "letter_weight",
      "label": "Letter weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Links"
    },
